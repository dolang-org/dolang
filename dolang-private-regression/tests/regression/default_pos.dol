import std:
 - args

def func foo = 42
  foo

assert_eq $func() 42
assert_eq (func false) false

bind []
  - a = 1
  - b = 2
assert_eq $a 1
assert_eq $b 2

bind [false]
  - a = 1
  - b = 2
assert_eq $a false
assert_eq $b 2

bind {}
  - a = 1
  - b = 2
assert_eq $a 1
assert_eq $b 2

bind {false}
  - a = 1
  - b = 2
assert_eq $a false
assert_eq $b 2

bind args()
  - a = 1
  - b = 2
assert_eq $a 1
assert_eq $b 2

bind args false
  - a = 1
  - b = 2
assert_eq $a false
assert_eq $b 2
