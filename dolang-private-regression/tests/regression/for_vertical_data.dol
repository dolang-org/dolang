let foo =
  for i = range end: 5
    - $i

assert_eq $foo [0, 1, 2, 3, 4]

let bar = 
  for i = range end: 5
    "$i": (i * 2)

assert_eq $bar {"0": 0, "1": 2, "2": 4, "3": 6, "4": 8}

let baz =
  for i = [1, 2]
    for j = ["a", "b"]
      - [i, j]

assert_eq $baz [[1, "a"], [1, "b"], [2, "a"], [2, "b"]]

let quux =
  for i = [1, 2]
    for j = [3, 4]
      (i * 10 + j): [i, j]

assert_eq $quux {13: [1, 3], 14: [1, 4], 23: [2, 3], 24: [2, 4]}
