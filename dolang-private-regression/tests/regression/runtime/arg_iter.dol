import std:
  - Iter
  - UnexpectedKeyError

def assert_err_type ty block
  let res = try
    block()
    false
  catch e
    assert_eq (type e) $ty
    true
  assert $res

def collect_pos ...args
  let pos = args.pos_only()
  assert (type pos Iter)
  [...pos]

def unpack_pos ...args
  let a b ...rest = args.pos_only()
  [a, b, [...rest]]

def spread_pos ...args
  let pos = args.pos_only()
  collect_pos ...pos

def split_args ...args
  let pos keyed = args.pos_keys()
  [[...pos], [...keyed], [...args]]

def consume_after_pos ...args
  let pos = args.pos_only()
  [[...pos], [...args]]

def iter_twice ...args
  [[...args], [...args]]

def spread_twice ...args
  [(collect_pairs ...args), (collect_pairs ...args)]

def collect_pairs ...args
  [...args]

assert (type (std.args 1 2) std.args)
assert_eq (collect_pos 1 2 3) [1, 2, 3]
assert_eq (unpack_pos 1 2 3 4) [1, 2, [3, 4]]
assert_eq (spread_pos 4 5 6) [4, 5, 6]
let consumed = consume_after_pos 7 8 9
assert_eq $consumed[0] [7, 8, 9]
assert_eq $consumed[1][0][0] 0
assert_eq $consumed[1][0][1] 7
assert_eq $consumed[1][1][0] 1
assert_eq $consumed[1][1][1] 8
assert_eq $consumed[1][2][0] 2
assert_eq $consumed[1][2][1] 9

let twice = iter_twice 1 left: 2 3
assert_eq $twice[0][0][0] 0
assert_eq $twice[0][0][1] 1
assert_eq $twice[0][1][0] :left:
assert_eq $twice[0][1][1] 2
assert_eq $twice[0][2][0] 1
assert_eq $twice[0][2][1] 3
assert_eq $twice[1][0][0] 0
assert_eq $twice[1][0][1] 1
assert_eq $twice[1][1][0] :left:
assert_eq $twice[1][1][1] 2
assert_eq $twice[1][2][0] 1
assert_eq $twice[1][2][1] 3

let spread = spread_twice 1 left: 2 3
assert_eq $spread[0][0][0] 0
assert_eq $spread[0][0][1] 1
assert_eq $spread[0][1][0] :left:
assert_eq $spread[0][1][1] 2
assert_eq $spread[0][2][0] 1
assert_eq $spread[0][2][1] 3
assert_eq $spread[1][0][0] 0
assert_eq $spread[1][0][1] 1
assert_eq $spread[1][1][0] :left:
assert_eq $spread[1][1][1] 2
assert_eq $spread[1][2][0] 1
assert_eq $spread[1][2][1] 3

let split = split_args 1 left: 2 3 right: 4
assert_eq $split[0] [1, 3]
assert_eq $split[1][0][0] :left:
assert_eq $split[1][0][1] 2
assert_eq $split[1][1][0] :right:
assert_eq $split[1][1][1] 4
assert_eq $split[2][0][0] 0
assert_eq $split[2][0][1] 1
assert_eq $split[2][1][0] :left:
assert_eq $split[2][1][1] 2
assert_eq $split[2][2][0] 1
assert_eq $split[2][2][1] 3
assert_eq $split[2][3][0] :right:
assert_eq $split[2][3][1] 4

split = split_args 1 2 3
assert_eq $split[0] [1, 2, 3]
assert_eq $split[1] []
assert_eq $split[2][0][0] 0
assert_eq $split[2][0][1] 1
assert_eq $split[2][1][0] 1
assert_eq $split[2][1][1] 2
assert_eq $split[2][2][0] 2
assert_eq $split[2][2][1] 3

split = split_args left: 2 right: 4
assert_eq $split[0] []
assert_eq $split[1][0][0] :left:
assert_eq $split[1][0][1] 2
assert_eq $split[1][1][0] :right:
assert_eq $split[1][1][1] 4
assert_eq $split[2][0][0] :left:
assert_eq $split[2][0][1] 2
assert_eq $split[2][1][0] :right:
assert_eq $split[2][1][1] 4

assert_err_type $UnexpectedKeyError do collect_pos 1 left: 2
