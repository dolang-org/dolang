let arr = [0, 1, 2, 3]
assert_eq $arr[1..3] [1, 2]
assert_eq $arr[..2] [0, 1]
assert_eq $arr[2..] [2, 3]
assert_eq $arr[..] [0, 1, 2, 3]
assert_eq $arr[-2..] [2, 3]
assert_eq $arr[..-1] [0, 1, 2]
assert_eq $arr[-3..-1] [1, 2]
assert_eq $arr[range 0 4 2] [0, 2]
assert_eq $arr[range 3 0 -1] [3, 2, 1]
assert_eq $arr[range nil nil -1] [3, 2, 1, 0]
assert_eq $arr[range 1 1 2] []

let tup = tuple([0, 1, 2, 3])
assert_eq $tup[1..3] (tuple [1, 2])
assert_eq $tup[..2] (tuple [0, 1])
assert_eq $tup[2..] (tuple [2, 3])
assert_eq $tup[..] (tuple [0, 1, 2, 3])
assert_eq $tup[-2..] (tuple [2, 3])
assert_eq $tup[..-1] (tuple [0, 1, 2])
assert_eq $tup[-3..-1] (tuple [1, 2])
assert_eq $tup[range 0 4 2] (tuple [0, 2])
assert_eq $tup[range 3 0 -1] (tuple [3, 2, 1])
assert_eq $tup[range nil nil -1] (tuple [3, 2, 1, 0])

let text = "abcd"
assert_eq $text[1..3] bc
assert_eq $text[..2] ab
assert_eq $text[2..] cd
assert_eq $text[..] abcd
assert_eq $text[-2..] cd
assert_eq $text[..-1] abc
assert_eq $text[-3..-1] bc

let data = b"abcd"
assert_eq $data[1..3] b"bc"
assert_eq $data[..2] b"ab"
assert_eq $data[2..] b"cd"
assert_eq $data[..] b"abcd"
assert_eq $data[-2..] b"cd"
assert_eq $data[..-1] b"abc"
assert_eq $data[-3..-1] b"bc"
assert_eq $data[range 0 4 2] b"ac"
assert_eq $data[range 3 0 -1] b"dcb"
assert_eq $data[range nil nil -1] b"dcba"

let values = []
for i = 2..
  if (i >= 5)
    break
  values.push $i
assert_eq $values [2, 3, 4]

let d = {}
d[1..3] = "hit"
assert_eq $d[1..3] "hit"
let same = 1..3
assert_eq $d[same] "hit"

let edit = [0, 1, 2, 3]
edit[1..3] = [9, 9]
assert_eq $edit [0, 9, 9, 3]
edit[1..3] = [8]
assert_eq $edit [0, 8, 3]
edit[1..2] = [4, 5, 6]
assert_eq $edit [0, 4, 5, 6, 3]
edit[1..4] = []
assert_eq $edit [0, 3]
edit[1..1] = (tuple [7, 8])
assert_eq $edit [0, 7, 8, 3]
edit[1..2] = range 4 7
assert_eq $edit [0, 4, 5, 6, 8, 3]
edit[..2] = [1]
assert_eq $edit [1, 5, 6, 8, 3]
edit[-1..] = [9, 10]
assert_eq $edit [1, 5, 6, 8, 9, 10]

let same_arr = [1, 2, 3]
same_arr[1..2] = same_arr
assert_eq $same_arr [1, 1, 2, 3, 3]

def assert_err msg block
  let ok = try
    block()
    false
  catch e
    assert_eq (str e) $msg
    true
  assert $ok

assert_err "index out of range or invalid" do
  arr[range 0 4 0]
assert_err "index out of range or invalid" do
  text[range 0 4 2]
assert_err "index out of range or invalid" do
  edit[range 0 4 2] = [1, 2]
