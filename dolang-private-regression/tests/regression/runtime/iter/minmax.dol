import
  std:
    - TypeError
  std:
    - IterStop

def assert_err_type ty block
  let res = try
    block()
    false
  catch e
    assert_eq (type e) $ty
    true
  assert $res

let it = [3, 1, 4, 1, 5].iter()
assert_eq (it.min()) 1
assert_err_type $IterStop do it.next()

it = [3, 1, 4, 1, 5].iter()
assert_eq (it.max()) 5
assert_err_type $IterStop do it.next()

let empty = [].iter()
assert_eq (empty.min default: 42) 42

empty = [].iter()
assert_eq (empty.max default: 42) 42

empty = [].iter()
assert_err_type $IterStop do empty.min()

let mapped = [1, 2, 3].iter().map (do |x| x * 2)
assert_eq (mapped.max()) 6

let filtered = [1, 2, 3, 4].iter().filter (do |x| x % 2 == 0)
assert_eq (filtered.min()) 2

let ranged = (range start: 5 end: 0 step: -1).iter()
assert_eq (ranged.min()) 1

let pair = ([10, 20]).pairs().max()
assert_eq $pair[0] 1
assert_eq $pair[1] 20

assert_err_type $TypeError do [1, "hello"].iter().min()
