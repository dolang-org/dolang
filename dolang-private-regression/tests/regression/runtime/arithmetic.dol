# Arithmetic
let min = -170141183460469231731687303715884105728
let max = 170141183460469231731687303715884105727
assert_eq  (1 + 1)   2
assert_eq  (2 - 1)   1
assert_eq  (2 * 2)   4
assert_eq  (4 / 2)   2
assert_eq  (4 % 3)   1
assert_eq  (-4 % 3)  2
assert_eq  (- 0)     0
assert_eq  (- 1)    -1
assert_eq  (- -1)    1
assert_eq  (5 / 2) 2.5
# Boxed arithmetic
assert_eq  (min - min) 0
assert_eq  (max - max) 0
assert_eq  (min + max) -1
# Boxed/unboxed arithmetic
assert_eq  (min + 1) -170141183460469231731687303715884105727
assert_eq  (max - 1) 170141183460469231731687303715884105726
assert_eq  (0 + min) $min
assert_eq  (0 + max) $max
assert_eq  (0 - max) -170141183460469231731687303715884105727
assert_eq  (min // 8) -21267647932558653966460912964485513216
assert_eq  (max // 8) 21267647932558653966460912964485513215
assert_eq  (1 // min) 0
assert_eq  (1 // max) 0
assert_eq  (8 << 1) 16
assert_eq  (8 >> 1) 4
assert_eq  (8 << 0) 8
assert_eq  (8 >> 0) 8

let caught = try
  (8 << (0 - 1))
catch _
  true
assert $caught

let caught = try
  (8 >> 128)
catch _
  true
assert $caught
