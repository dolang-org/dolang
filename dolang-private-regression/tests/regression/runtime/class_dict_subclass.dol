# Basic subclassing of dict
class MyDict: dict
  def (init) self source
    dict.(init) $self $source

let d = MyDict {"a": 1, "b": 2}

# Length
assert_eq $d.len 2

# Indexing
assert_eq $d["a"] 1
assert_eq $d["b"] 2

# Contains
assert (d.contains "a")
assert (!(d.contains "c"))

# Iteration
let sum = 0
for _ v = d
  sum = (sum + v)
assert_eq $sum 3

# Coercion
assert_eq (str d) r#"{"a": 1, "b": 2}"#

let copied = d.copy()
assert (type copied MyDict)
copied.insert "c" 3
assert_eq (str d) r#"{"a": 1, "b": 2}"#
assert_eq (str copied) r#"{"a": 1, "b": 2, "c": 3}"#
