import strand:
  - stream
  - fork
  - each
  - put

# Test 1: basic stream — each branch doubles values
let s = stream do each do |x| (x * 2)
let s_input = s.sink()
let s_output = s.iter()

# Producer and consumer run concurrently (channels are size-1)
let results = fork
  do 
    s_input.put 1
    s_input.put 2
    s_input.put 3
  do [s_output.next(), s_output.next(), s_output.next()]

# join closes the input channel (strand's each exits) and waits for completion
s.join()
assert_eq $results[1] [2, 4, 6]

# Test 2: strand error propagates to consumer via next
# The strand puts one value then throws; next should surface the error after the value.
let s2 = stream do
  put 42
  throw "next error"
let s2_output = s2.iter()
let v = s2_output.next()
assert_eq $v 42
let err2 = try
  s2_output.next()
catch e
  e
s2.wait()
assert_eq $err2 "next error"

# Test 3: producer observes plain SinkStop when the consumer strand fails.
let s3 = stream do throw "put error"
let s3_input = s3.sink()
let err3 = try
  s3_input.put 1
  s3_input.put 2
catch e
  e
s3.wait()
assert_eq (str err3) "sink stopped"

# Test 4: iter()/sink() expose ordinary channel endpoints.
let s4 = stream do each do |x| x
let mapped = s4.iter().map (do |x| x + 1)
let s4_input = s4.sink()
let results4 = fork
  do s4_input.put 1
  do mapped.next()
s4.join()
assert_eq $results4[1] 2
