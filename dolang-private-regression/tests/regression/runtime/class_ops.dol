# Test operator special methods for classes

# 2D vector class to test math operators and equality
class Vec2
pub let x = 0
pub let y = 0

def (init) self x y
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (init) self x y
  #    |      ^^^^
  self.x = x
  self.y = y

def (add) self other
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (add) self other
  #    |      ^^^
  Vec2 (self.x + other.x) (self.y + other.y)

def (sub) self other
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (sub) self other
  #    |      ^^^
  Vec2 (self.x - other.x) (self.y - other.y)

def (mul) self scalar
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (mul) self scalar
  #    |      ^^^
  Vec2 (self.x * scalar) (self.y * scalar)

def (neg) self
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (neg) self
  #    |      ^^^
  Vec2 (0 - self.x) (0 - self.y)

def (eq) self other
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (eq) self other
  #    |      ^^
  (self.x == other.x && self.y == other.y)

def (bool) self
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (bool) self
  #    |      ^^^^
  (self.x != 0 || self.y != 0)

def (str) self
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (str) self
  #    |      ^^^
  "Vec2($(self.x), $(self.y))"

let a = Vec2 1 2
let b = Vec2 3 4

# Test (add)
let c = (a + b)
assert_eq (c.x) 4
assert_eq (c.y) 6

# Test (sub)
let d = (b - a)
assert_eq (d.x) 2
assert_eq (d.y) 2

# Test (mul)
let e = (a * 3)
assert_eq (e.x) 3
assert_eq (e.y) 6

# Test (neg)
let f = (-a)
assert_eq (f.x) -1
assert_eq (f.y) -2

# Test (eq)
assert (a == Vec2 1 2)
assert_not (a == b)

# Test (bool) - zero vector is falsy
let zero = Vec2 0 0
assert (bool a)
assert_not (bool zero)

# Test index operators
class Table
pub let data = nil

def (init) self
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (init) self
  #    |      ^^^^
  self.data = {}

def (index) self key
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (index) self key
  #    |      ^^^^^
  self.data[key]

def (assign) self key value
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (assign) self key value
  #    |      ^^^^^^
  self.data[key] = value

let t = Table()
t["x"] = 10
t["y"] = 20
assert_eq $t["x"] 10
assert_eq $t["y"] 20

# Test (lt) for ordering
class Num
pub let val = 0

def (init) self val
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (init) self val
  #    |      ^^^^
  self.val = val

def (lt) self other
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (lt) self other
  #    |      ^^
  (self.val < other.val)

def (eq) self other
  # error: special methods are only valid in a class body
  #   --> class_ops.dol:LL:LL
  #    |
  # LL | def (eq) self other
  #    |      ^^
  (self.val == other.val)

let n1 = Num 1
let n2 = Num 2
let n3 = Num 1

assert (n1 < n2)
assert_not (n2 < n1)
assert_not (n1 < n3)
assert (n1 <= n3)
assert (n2 > n1)
assert (n2 >= n1)
