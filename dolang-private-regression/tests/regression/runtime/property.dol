class Example
  pub let storage = 1
  #[property]
  pub def value obj
    obj.storage

  #[value.setter]
  pub def value obj value
    obj.storage = value

let ex = Example()
assert_eq $ex.value 1
ex.value = 42
assert_eq $ex.value 42
assert_eq $ex.storage 42

class Base
  pub let storage = 7
  pub let value = property do |obj| obj.storage

class Derived: Base

let derived = Derived()
assert_eq $derived.value 7

def greet name
  "hello $name"

class CallableProperty
  pub let action = property do |_obj| greet

let callable = CallableProperty()
assert_eq $callable.action("world") "hello world"

class AssignedProperty
  pub let value = nil

  def (init) self desc
    self.value = desc

let prop = property do |_obj| "descriptor result"
let assigned = AssignedProperty $prop
assert_eq $assigned.value $prop

class ReadOnly
  pub let value = property do |_obj| "read only"

let ro = ReadOnly()
assert_eq $ro.value "read only"
let failed = false
try
  ro.value = "new"
catch err
  assert_eq (str err) "type error: property has no setter"
  failed = true
assert $failed
