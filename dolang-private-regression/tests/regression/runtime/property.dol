class Example
  pub let storage = 1
  #[getter]
  pub def value obj
    obj.storage

  #[setter]
  pub def value obj value
    obj.storage = value

let ex = Example()
assert_eq $ex.value 1
ex.value = 42
assert_eq $ex.value 42
assert_eq $ex.storage 42

class Base
  pub let storage = 7
  pub let value = getter do |obj| obj.storage

class Derived: Base

let derived = Derived()
assert_eq $derived.value 7

def greet name
  "hello $name"

class CallableProperty
  pub let action = getter do |_obj| greet

let callable = CallableProperty()
assert_eq $callable.action("world") "hello world"

class ReadOnly
  pub let value = getter do |_obj| "read only"

let ro = ReadOnly()
assert_eq $ro.value "read only"
let failed = false
try
  ro.value = "new"
catch err
  assert_eq (str err) "no such field: value"
  failed = true
assert $failed

let duplicate_getter = false
try
  class _DuplicateGetter
    #[getter]
    pub def value _obj
      1

    #[getter]
    pub def value _obj
      2
catch err
  assert_eq (str err) "class_create: duplicate class member `value`"
  duplicate_getter = true
assert $duplicate_getter

let getter_field_conflict = false
try
  class _GetterFieldConflict
    #[getter]
    pub def value _obj
      1

    pub let value = 2
catch err
  assert_eq (str err) "class_create: duplicate class member `value`"
  getter_field_conflict = true
assert $getter_field_conflict
