# Test private fields and methods for classes

# Basic private field access via .#field
class Counter
  field count = 0

  def (init) self start
    self.#count = start

  pub def increment self
    self.#count = (self.#count + 1)

  pub def value self
    self.#count

let c = Counter 10
assert_eq $c.value() 10
c.increment()
assert_eq $c.value() 11

# Private methods
class Adder
  field base = 0

  def (init) self base
    self.#base = base

  def double_base self
    (self.#base * 2)

  pub def add self x
    (self.#double_base() + x)

let a = Adder 5
assert_eq $a.add(3) 13

# Two classes with same private field name - must not conflict
class Box
  field value = 0

  def (init) self v
    self.#value = v

  pub def get self
    self.#value

class Wrapper
  field value = 0

  def (init) self v
    self.#value = v

  pub def get self
    self.#value

let b1 = Box 42
let w1 = Wrapper 99

assert_eq $b1.get() 42
assert_eq $w1.get() 99
