import
  std:
    - UnsupportedError
    - ImmutableError
    - ConcurrencyError
    - TypeError
    - ValueError
    - StateError
    - IndexError
    - FieldError
    - UnexpectedPosError
    - UnexpectedKeyError
    - MissingPosError
    - MissingKeyError
    - OverflowError
    - ZeroDivError
    - CyclicImportError
    - ImportError
    - CompileError
    - RuntimeError
    - AbortError
    - BytecodeError
    - CanceledError
    - TimedOutError
    - IterStop
    - SinkStop

def assert_ctor ty :msg ...rest
  let err = ty ...rest
  assert (type err ty)
  assert_eq (str err) $msg

def assert_ctor_fail func type: ty :msg ...rest
  let res = try
    func ...rest
    false
  catch e
    assert (type e ty)
    assert_eq (str e) $msg
    true
  assert $res

let type_err = TypeError "bad"
assert_eq (type type_err) $TypeError
assert_eq (str type_err) "type error: bad"
assert (type type_err RuntimeError)

let value_err = ValueError "bad"
assert_eq (type value_err) $ValueError
assert_eq (str value_err) "value error: bad"
assert (type value_err RuntimeError)

let state_err = StateError "closed"
assert_eq (type state_err) $StateError
assert_eq (str state_err) "state error: closed"
assert (type state_err RuntimeError)

let field_err = FieldError :name:
assert_eq (type field_err) $FieldError
assert_eq (str field_err) "no such field: name"

let sink_stop = SinkStop()
assert_eq (type sink_stop) $SinkStop
assert_eq (str sink_stop) "sink stopped"

assert_ctor $UnsupportedError msg: "unsupported operation"
assert_ctor $ImmutableError msg: "object is immutable"
assert_ctor $ConcurrencyError msg: "conflicting concurrent operation"
assert_ctor $ConcurrencyError msg: "conflicting concurrent operation: shared" "shared"
assert_ctor $TypeError msg: "type error: expected int" "expected int"
assert_ctor $ValueError msg: "value error: expected mode" "expected mode"
assert_ctor $StateError msg: "state error: closed" "closed"
assert_ctor $IndexError msg: "index out of range or invalid"
assert_ctor $FieldError msg: "no such field: name" :name:
assert_ctor $UnexpectedPosError msg: "unexpected positional item: 2" 2
assert_ctor $UnexpectedKeyError msg: "unexpected key item: key3" :key3:
assert_ctor $MissingPosError msg: "missing positional item: 3" 3
assert_ctor $MissingKeyError msg: "missing key item: key4" :key4:
assert_ctor $OverflowError msg: "numeric overflow"
assert_ctor $ZeroDivError msg: "integer zero divisor"
assert_ctor $IterStop msg: "iterator stopped"
assert_ctor $SinkStop msg: "sink stopped"
assert_ctor $CyclicImportError msg: "cycle detected importing module: pkg.mod" "pkg.mod"
assert_ctor $ImportError msg: "module not found: pkg.mod" "pkg.mod"
assert_ctor $CompileError msg: "compile error: invalid token" "invalid token"
assert_ctor $RuntimeError msg: "closed" "closed"
assert_ctor $CanceledError msg: "strand canceled"
assert_ctor $TimedOutError msg: "strand timed out"

assert_ctor_fail $MissingPosError type: $TypeError msg: "type error: expected `int`" "bad"
assert_ctor_fail $UnexpectedPosError type: $ValueError msg: "value error: expected non-negative value" -1
assert_ctor_fail $TypeError type: $TypeError msg: "type error: expected `str`" 123
assert_ctor_fail $ValueError type: $TypeError msg: "type error: expected `str`" 123
assert_ctor_fail $StateError type: $TypeError msg: "type error: expected `str`" 123
assert_ctor_fail $FieldError type: $TypeError msg: "type error: expected `sym`" 123
assert_ctor_fail $ImportError type: $TypeError msg: "type error: expected `str`" 123
assert_ctor_fail $CompileError type: $TypeError msg: "type error: expected `str`" 123
assert_ctor_fail $RuntimeError type: $TypeError msg: "type error: expected `str`" 123

assert_ctor_fail $AbortError type: $TypeError msg: "type error: Abort is not instantiable" "stop"
assert_ctor_fail $BytecodeError type: $TypeError msg: "type error: Bytecode is not instantiable" "bad"
