# Binary string literals and operations

# Empty binary string
assert_eq (b"".len) 0
assert (!(bool b""))

# Simple ASCII binary string
assert_eq (b"hello".len) 5
assert (bool b"hello")

# Binary strings compare equal to themselves
assert_eq b"hello" b"hello"
assert (!(b"hello" == b"world"))

# Ordering
assert (b"abc" < b"abd")
assert (!(b"abd" < b"abc"))

# Hex escape: \x41 == 'A'
assert_eq b"\x41\x42\x43" b"ABC"
assert_eq (b"\x41\x42\x43".len) 3

# Non-ASCII bytes
assert_eq (b"\xff".len) 1
assert_eq (b"\x00".len) 1

# Concatenation via interpolation
let prefix = b"foo"
let suffix = b"bar"
assert_eq b"$prefix$suffix" b"foobar"

# Interpolation with text
assert_eq b"hello $prefix" b"hello foo"

# Nested hex escapes in interpolation
assert_eq b"\x41$prefix\x42" b"AfooB"

# Length field
assert_eq (b"abc".len) 3

# Slice indexing
assert_eq (b"foobar"[2..]) b"obar"
assert_eq (b"foobar"[2..4]) b"ob"
assert_eq (b"foobar"[1..1]) b""
assert_eq (b"foobar"[-3..]) b"bar"
assert_eq (b"foobar"[1..-1]) b"ooba"
assert_eq (b"foobar"[-4..-1]) b"oba"
assert_eq (b"foobar"[-6..6]) b"foobar"

# Scalar indexing
assert_eq (b"\x12\x34"[0]) 18
assert_eq (b"\x12\x34"[1]) 52
assert_eq (b"\x12\x34"[-1]) 52
assert_eq (b"\x12\x34"[-2]) 18

# Fixed-width integer codecs
assert_eq (int.from_u8(b"\xff")) 255
assert_eq (bin.from_u8(255)) b"\xff"
assert_eq (int.from_i8(b"\xff")) -1
assert_eq (bin.from_i8(-1)) b"\xff"

assert_eq (int.from_u16_le(b"\x34\x12")) 0x1234
assert_eq (int.from_u16_be(b"\x12\x34")) 0x1234
assert_eq (bin.from_u16_le(0x1234)) b"\x34\x12"
assert_eq (bin.from_u16_be(0x1234)) b"\x12\x34"

assert_eq (int.from_i16_le(b"\xcc\xed")) -0x1234
assert_eq (int.from_i16_be(b"\xed\xcc")) -0x1234
assert_eq (bin.from_i16_le(-0x1234)) b"\xcc\xed"
assert_eq (bin.from_i16_be(-0x1234)) b"\xed\xcc"

assert_eq (int.from_u32_le(b"\x78\x56\x34\x12")) 0x12345678
assert_eq (int.from_u32_be(b"\x12\x34\x56\x78")) 0x12345678
assert_eq (bin.from_u32_le(0x12345678)) b"\x78\x56\x34\x12"
assert_eq (bin.from_u32_be(0x12345678)) b"\x12\x34\x56\x78"

assert_eq (int.from_i32_le(b"\x88\xa9\xcb\xed")) -0x12345678
assert_eq (int.from_i32_be(b"\xed\xcb\xa9\x88")) -0x12345678
assert_eq (bin.from_i32_le(-0x12345678)) b"\x88\xa9\xcb\xed"
assert_eq (bin.from_i32_be(-0x12345678)) b"\xed\xcb\xa9\x88"

assert_eq (int.from_u64_le(b"\xef\xcd\xab\x89\x67\x45\x23\x01")) 0x0123456789abcdef
assert_eq (int.from_u64_be(b"\x01\x23\x45\x67\x89\xab\xcd\xef")) 0x0123456789abcdef
assert_eq (bin.from_u64_le(0x0123456789abcdef)) b"\xef\xcd\xab\x89\x67\x45\x23\x01"
assert_eq (bin.from_u64_be(0x0123456789abcdef)) b"\x01\x23\x45\x67\x89\xab\xcd\xef"

assert_eq (int.from_i64_le(b"\x11\x32\x54\x76\x98\xba\xdc\xfe")) -0x0123456789abcdef
assert_eq (int.from_i64_be(b"\xfe\xdc\xba\x98\x76\x54\x32\x11")) -0x0123456789abcdef
assert_eq (bin.from_i64_le(-0x0123456789abcdef)) b"\x11\x32\x54\x76\x98\xba\xdc\xfe"
assert_eq (bin.from_i64_be(-0x0123456789abcdef)) b"\xfe\xdc\xba\x98\x76\x54\x32\x11"

# Starts/ends with
assert (b"foobar".starts_with b"foo")
assert (b"foobar".ends_with b"bar")
assert (!(b"foobar".starts_with b"bar"))

# Without prefix/suffix
assert_eq (b"foobar".without_prefix b"foo") b"bar"
assert_eq (b"foobar".without_prefix b"bar") b"foobar"
assert_eq (b"foobar".without_suffix b"bar") b"foo"
assert_eq (b"foobar".without_suffix b"foo") b"foobar"

# Contains
assert (b"foobar".contains b"foo")
assert (b"foobar".contains b"bar")
assert (b"foobar".contains b"oba")
assert (b"foobar".contains b"")
assert (!(b"foobar".contains b"baz"))

# Split and join
assert_eq [..."a,b,c".split ","] ["a", "b", "c"]
assert_eq [...b"a,b,c".split b","] [b"a", b"b", b"c"]
assert_eq [...b"a,b,c".split b"," limit: 1] [b"a", b"b,c"]
assert_eq [...b"a.b.tar.gz".split b"." limit: -1] [b"a.b.tar", b"gz"]
assert_eq [...b"a,b,c".rsplit b","] [b"c", b"b", b"a"]
assert_eq [...b"a,b,c".rsplit b"," limit: 1] [b"c", b"a,b"]
assert_eq [...b"a,b,c".rsplit b"," limit: -1] [b"b,c", b"a"]
let parts = [b"hello", b"world"]
assert_eq (b", ".join parts) b"hello, world"

# Unpack into byte array
let bytes = b"\x01\x02\x03".unpack()
assert_eq [...bytes] [1, 2, 3]

# Lowercase hex encoding
assert_eq (b"ABC".hex()) "414243"
assert_eq (b"\x00\x01\xff".hex()) "0001ff"

# bin is not equal to str even when bytes match
assert (!(b"hello" == "hello"))

# type is bin
assert_eq (type b"hello") $bin

def assert_err msg block
  let res = try
    block()
    false
  catch e
    assert_eq (str e) $msg
    true
  assert $res

assert_err "index out of range or invalid" do b"foobar"[-99..]
assert_err "index out of range or invalid" do b"foobar"[0..-99]
assert_err "index out of range or invalid" do b"foobar"[99]
assert_err "type error: expected `bin` of length 2" do int.from_u16_le(b"\x12")
assert_err "numeric overflow" do bin.from_u8(256)
