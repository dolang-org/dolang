for i = range start: 0 end: 5
  echo $i
for i = range start: 5 end: 0 step: -1
  echo $i
echo (range start: 3.14159 end: 22 step: 0.33)

# contains tests - range is [start, end) inclusive start, exclusive end
let r1 = range start: 0 end: 5
assert (r1.contains 0)
assert (r1.contains 1)
assert (r1.contains 4)
assert (!r1.contains 5)
assert (!r1.contains -1)
assert (!r1.contains 100)

# reversed range (decreasing)
let r2 = range start: 5 end: 0 step: -1
assert (r2.contains 5)
assert (r2.contains 4)
assert (r2.contains 1)
assert (!r2.contains 0)
assert (!r2.contains 6)

# float range
let r3 = range start: 0.0 end: 5.0
assert (r3.contains 0.0)
assert (r3.contains 2.5)
assert (r3.contains 4.9)
assert (!r3.contains 5.0)
assert (!r3.contains -0.1)

# output: END
# 0
# 1
# 2
# 3
# 4
# 5
# 4
# 3
# 2
# 1
# <range start: 3.14159, end: 22, step: 0.33>
# END
