import
  strand:
    - channel
    - fork
    - limit
    - spawn
  std:
    - ValueError

def assert_err_type ty block
  let res = try
    block()
    false
  catch e
    assert (type e ty)
    true
  assert $res

# strand.limit constrains total active fork workers across the scope, even when
# a single fork site would otherwise fan out more aggressively.
let release_send release_recv = channel 8
let entered_send entered_recv = channel 8
let active = 0
let max_active = 0
let helper = spawn do
  entered_recv.next()
  entered_recv.next()
  for _ = range 4
    release_send.put ok

let basic = limit 2 do
  fork limit: 4
    do
      entered_send.put :a:
      active = (active + 1)
      if (active > max_active)
        max_active = active
      release_recv.next()
      active = (active - 1)
      :a:
    do
      entered_send.put :b:
      active = (active + 1)
      if (active > max_active)
        max_active = active
      release_recv.next()
      active = (active - 1)
      :b:
    do
      entered_send.put :c:
      active = (active + 1)
      if (active > max_active)
        max_active = active
      release_recv.next()
      active = (active - 1)
      :c:
    do
      entered_send.put :d:
      active = (active + 1)
      if (active > max_active)
        max_active = active
      release_recv.next()
      active = (active - 1)
      :d:

helper.join()
assert_eq $basic [:a:, :b:, :c:, :d:]
assert_eq $max_active 2

# Nested strand.limit scopes compose by adding another transitive constraint.
let release_send release_recv = channel 8
let entered_send entered_recv = channel 8
active = 0
max_active = 0
helper = spawn do
  entered_recv.next()
  for _ = range 4
    release_send.put ok

let composed = limit 2 do
  limit 1 do
    fork limit: 4
      do
        entered_send.put :w:
        active = (active + 1)
        if (active > max_active)
          max_active = active
        release_recv.next()
        active = (active - 1)
        :w:
      do
        entered_send.put :x:
        active = (active + 1)
        if (active > max_active)
          max_active = active
        release_recv.next()
        active = (active - 1)
        :x:
      do
        entered_send.put :y:
        active = (active + 1)
        if (active > max_active)
          max_active = active
        release_recv.next()
        active = (active - 1)
        :y:
      do
        entered_send.put :z:
        active = (active + 1)
        if (active > max_active)
          max_active = active
        release_recv.next()
        active = (active - 1)
        :z:

helper.join()
assert_eq $composed [:w:, :x:, :y:, :z:]
assert_eq $max_active 1

# fork limit: remains a separate immediate fan-out policy.
let release_send release_recv = channel 8
let entered_send entered_recv = channel 8
active = 0
max_active = 0
helper = spawn do
  entered_recv.next()
  for _ = range 4
    release_send.put ok

let immediate = limit 4 do
  fork limit: 1
    do
      entered_send.put 1
      active = (active + 1)
      if (active > max_active)
        max_active = active
      release_recv.next()
      active = (active - 1)
      1
    do
      entered_send.put 2
      active = (active + 1)
      if (active > max_active)
        max_active = active
      release_recv.next()
      active = (active - 1)
      2
    do
      entered_send.put 3
      active = (active + 1)
      if (active > max_active)
        max_active = active
      release_recv.next()
      active = (active - 1)
      3
    do
      entered_send.put 4
      active = (active + 1)
      if (active > max_active)
        max_active = active
      release_recv.next()
      active = (active - 1)
      4

helper.join()
assert_eq $immediate [1, 2, 3, 4]
assert_eq $max_active 1

# A blocked nested fork coordinator should not consume the transitive budget.
let release_nested_send release_nested_recv = channel 1
let entered_nested_send entered_nested_recv = channel 1
helper = spawn do
  let started = entered_nested_recv.next()
  release_nested_send.put ok
  started

let nested = limit 1 do
  fork
    do
      let inner = fork
        do
          entered_nested_send.put :started:
          release_nested_recv.next()
          42
      inner[0]

assert_eq $nested [42]
assert_eq (helper.join()) :started:

# Nested fork errors should not poison later acquisitions.
let err = try
  limit 1 do
    fork
      do
        let _ = fork
          do throw "boom"
catch e
  e
assert_eq (str err) "boom"

assert_eq (limit 1 do fork do 7) [7]

assert_err_type $ValueError do limit 0 do nil
