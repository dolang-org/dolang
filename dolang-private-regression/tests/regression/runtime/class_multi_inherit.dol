class A
  pub let x = 1
  pub def greet _self
    "from A"

class B: A
  pub let y = 2
  pub def greet _self
    "from B"

class C: A
  pub let z = 3

# Diamond: D gets fields x, y, z, w; method greet from B (left wins)
class D: B C
  pub let w = 4

let d = D()
assert_eq $d.x 1
assert_eq $d.y 2
assert_eq $d.z 3
assert_eq $d.w 4
assert_eq $d.greet() "from B"

for ty = [A, B, C, D]
  assert (type d ty)

# Reversed order: E: C B → C comes first, but C doesn't override greet, so falls to A
class E: C B
let e = E()
assert_eq $e.greet() "from A"
