import std:
  - Descriptor

class Property: Descriptor
  pub let getter = nil
  pub let setter_fn = nil

  def (init) self getter
    self.getter = getter

  pub def get self obj
    self.getter $obj

  pub def set self obj value
    self.setter_fn $obj $value

  pub def setter self fn
    self.setter_fn = fn
    self

class Example
  pub let storage = 1
  pub let value = Property do |obj| obj.storage

  #[value.setter]
  pub def value obj value
    obj.storage = value

let ex = Example()
assert_eq $ex.value 1
ex.value = 42
assert_eq $ex.value 42
assert_eq $ex.storage 42

class Base
  pub let storage = 7
  pub let value = Property do |obj| obj.storage

class Derived: Base

let derived = Derived()
assert_eq $derived.value 7

def greet name
  "hello $name"

class CallableProperty
  pub let action = Property do |_obj| greet

let callable = CallableProperty()
assert_eq $callable.action("world") "hello world"

class LooksLikeDescriptor
  pub def get _self _obj
    "not a descriptor"

class OrdinaryField
  pub let value = LooksLikeDescriptor()

let ordinary = OrdinaryField()
assert_eq $ordinary.value.get(nil) "not a descriptor"

class AssignedDescriptor
  pub let value = nil

  def (init) self desc
    self.value = desc

let prop = Property do |_obj| "descriptor result"
let assigned = AssignedDescriptor $prop
assert_eq $assigned.value $prop

class ReadOnly
  pub let value = Property do |_obj| "read only"

let ro = ReadOnly()
assert_eq $ro.value "read only"
let failed = false
try
  ro.value = "new"
catch _
  failed = true
assert $failed
