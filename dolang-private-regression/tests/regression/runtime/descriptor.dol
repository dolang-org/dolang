import std:
  - Getter
  - Setter

class PropertyGetter: Getter
  pub field getter = nil

  def (init) self getter
    self.getter = getter

  pub def get self obj
    self.getter $obj

class _PropertySetter: Setter
  pub field setter_fn = nil

  pub def set self obj value
    self.setter_fn $obj $value

  def (init) self fn
    self.setter_fn = fn

class Example
  pub field storage = 1

  #[getter]
  pub def value obj
    obj.storage

  #[setter]
  pub def value obj value
    obj.storage = value

let ex = Example()
assert_eq $ex.value 1
ex.value = 42
assert_eq $ex.value 42
assert_eq $ex.storage 42

class Base
  pub field storage = 7

  #[getter]
  pub def value obj
    obj.storage

class Derived: Base

let derived = Derived()
assert_eq $derived.value 7

def greet name
  "hello $name"

class CallableProperty
  #[getter]
  pub def action _obj
    greet

let callable = CallableProperty()
assert_eq $callable.action("world") "hello world"

class LooksLikeGetter
  pub def get _self _obj
    "not a getter"

class OrdinaryField
  pub field value

  def (init) self
    self.value = LooksLikeGetter()

let ordinary = OrdinaryField()
assert_eq $ordinary.value.get(nil) "not a getter"

class AssignedGetter
  pub field value = nil

  def (init) self desc
    self.value = desc

let prop = PropertyGetter do |_obj| "getter result"
let assigned = AssignedGetter $prop
assert_eq $assigned.value $prop

let duplicate_setter = false
try
  class _DuplicateSetter
    #[setter]
    pub def value _obj _value
      nil

    #[setter]
    pub def value _obj _value
      nil
catch err
  assert_eq (str err) "class_create: duplicate class member `value`"
  duplicate_setter = true
assert $duplicate_setter
