# Basic subclassing of array
class MyArray: array
  def (init) self source
    array.(init) $self $source

let a = MyArray [1, 2, 3]

# Length
assert_eq $a.len 3

# Indexing
assert_eq $a[0] 1
assert_eq $a[2] 3

# Iteration
let sum = 0
for v = a
  sum = (sum + v)
assert_eq $sum 6

# Coercion
assert_eq (str a) "[1, 2, 3]"

# Comparison
let b = MyArray [1, 2, 3]
assert (a == b)

let c = a.copy()
assert (type c MyArray)
c.push 4
assert_eq $a [1, 2, 3]
assert_eq $c [1, 2, 3, 4]
