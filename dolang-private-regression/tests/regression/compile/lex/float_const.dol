assert_eq 5.0 (5.0)
assert_eq 5. (5.0)
assert_eq .5 (.5)
assert_eq 1.2e-5 (1.2e-5)
assert_eq 1.2e+5 (1.2e+5)
assert_eq 1.2e5 (1.2e5)
assert_eq 1e5 (1e5)
# Verify fallback to literal strings
assert_eq 5.0foo "5.0foo"
assert_eq 0.foo "0.foo"
assert_eq 5.0e+foo "5.0e+foo"
assert_eq 5e+foo "5e+foo"
assert_eq 5efoo "5efoo"
assert_eq .foo ".foo"
