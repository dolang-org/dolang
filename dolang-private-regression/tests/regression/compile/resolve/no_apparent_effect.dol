# LL | let _ = (-x)
#    | +++++++

# String concatenation with variable
"hello $x"
# warning: statement with no apparent effect
#   --> no_apparent_effect.dol:LL:LL
#    |
# LL | "hello $x"
#    | ^^^^^^^^^^
#    |
# help: bind result to _ to suppress warning
