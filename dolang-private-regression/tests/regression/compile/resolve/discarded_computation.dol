# LL | [echo(), echo()]
#    | ^^^^^^^^^^^^^^^^
#    |
# help: bind result to _ to suppress warning
#    |
# LL | let _ = [echo(), echo()]
#    | +++++++

# Dict literal with function call values
{a: echo(), b: echo()}
# warning: result of computation discarded
#   --> discarded_computation.dol:LL:LL
#    |
# LL | {a: echo(), b: echo()}
#    | ^^^^^^^^^^^^^^^^^^^^^^
#    |
# help: bind result to _ to suppress warning
#    |
# LL | let _ = {a: echo(), b: echo()}
#    | +++++++

# Field access on function call result
(echo().field)
# warning: result of computation discarded
#   --> discarded_computation.dol:LL:LL
#    |
# LL | (echo().field)
#    | ^^^^^^^^^^^^^^
#    |
# help: bind result to _ to suppress warning
#    |
