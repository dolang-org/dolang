# Test: warning when accessing a private field via .field on self

pub class Counter
  field count = 0

  def (init) self start
    self.#count = start

  pub def bad_read self
    self.count
    # warning: `count` is private
    #   --> class_private_warning.dol:LL:LL
    #    |
    # LL |     self.count
    #    |          ^^^^^
    #    |
    # help: use `.#` to access private field
    #    |
    # LL |     self.#count
    #    |          +
