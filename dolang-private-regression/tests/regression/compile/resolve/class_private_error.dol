# Test: no private field `x` in scope errors

# Accessing a private field from outside the class via .#field get
class Box
  field val = 0

  def (init) self v
    self.#val = v

let b = Box 5
let _ = b.#val
# error: no private field `val` in scope
#   --> class_private_error.dol:LL:LL
#    |
# LL | let _ = b.#val
#    |            ^^^

# Assigning a private field from outside the class via .#field set
class Jar
  field contents = nil

  def (init) self v
    self.#contents = v

let j = Jar "beans"
j.#contents = "rice"
# error: no private field `contents` in scope
#   --> class_private_error.dol:LL:LL
#    |
# LL | j.#contents = "rice"
#    |    ^^^^^^^^

# Accessing another class's private field from within a different class
pub class Counter
  field n = 0

  def (init) self start
    self.#n = start

pub class Spy
  pub def peek _self other
    other.#n
# error: no private field `n` in scope
#   --> class_private_error.dol:LL:LL
#    |
# LL |     other.#n
#    |            ^
