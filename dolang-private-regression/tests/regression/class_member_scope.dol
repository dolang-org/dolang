class PassThrough
  pub def (call) _self fn
    do |...args| fn ...args

class Example
  let setter = PassThrough()

  #[setter]
  pub def value _self
    42

  let secret = 7
  pub let exposed = secret

let ex = Example()
assert_eq $ex.value() 42
assert_eq $ex.exposed 7

class NestedClass
  pub class Inner
    pub let value = 1

  pub let inner = Inner()

let nested = NestedClass()
assert_eq $nested.inner.value 1

let shadowed = 2

class MethodGlobalFallback
  let shadowed = 1

  pub def value _self
    shadowed

let fallback = MethodGlobalFallback()
assert_eq $fallback.value() 2
