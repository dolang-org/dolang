# Test recursive and co-recursive def

# Direct recursion
def fib n
  if (n <= 1)
    n
  else
    (fib (n - 1) + fib (n - 2))

assert_eq (fib 0) 0
assert_eq (fib 1) 1
assert_eq (fib 10) 55

# Co-recursion (mutual recursion)
def is_even n
  if (n == 0)
    true
  else
    is_odd (n - 1)

def is_odd n
  if (n == 0)
    false
  else
    is_even (n - 1)

assert_eq (is_even 4) true
assert_eq (is_odd 3) true
assert_eq (is_even 7) false
