import toml:
  - from_str
  - to_str

def assert_err_contains needle block
  let res = try
    block()
    false
  catch e
    assert $ (str e).contains $needle
    true
  assert $res

# Bare values
assert_eq (from_str "42") 42
assert_eq (from_str "3.14") 3.14
assert_eq (from_str "true") true
assert_eq (from_str "\"hello\"") "hello"
assert_eq (from_str "[1, 2, 3]") [1, 2, 3]

# Inline tables
let inline = from_str "{ a = 1, b = \"two\" }"
assert_eq $inline["a"] 1
assert_eq $inline["b"] "two"

# Documents and nested tables
let doc = from_str "title = \"TOML\"\n[server]\nport = 8080\nenabled = true\n"
assert_eq $doc["title"] "TOML"
assert_eq $doc["server"]["port"] 8080
assert_eq $doc["server"]["enabled"] true

# Arrays of tables
let users = from_str "[[users]]\nname = \"alice\"\n[[users]]\nname = \"bob\"\n"
assert_eq $users["users"][0]["name"] "alice"
assert_eq $users["users"][1]["name"] "bob"

# Scalar round-trips
assert_eq (from_str $ to_str 42) 42
assert_eq (from_str $ to_str 3.14) 3.14
assert_eq (from_str $ to_str true) true
assert_eq (from_str $ to_str "hello") "hello"

# Arrays and tuples
assert_eq (from_str $ to_str [1, 2, 3]) [1, 2, 3]
assert_eq (from_str $ to_str $ tuple([1, 2, 3])) [1, 2, 3]

# Dicts and records
let obj = {"name": "alice", "age": 30}
let rt_obj = from_str $ to_str $obj
assert_eq $rt_obj["name"] "alice"
assert_eq $rt_obj["age"] 30

let rec = record enabled: true port: 8080
let rt_rec = from_str $ to_str $rec
assert_eq $rt_rec["enabled"] true
assert_eq $rt_rec["port"] 8080

# Symbol keys stringify
let sym_dict = {}
sym_dict[:name:] = "alice"
let rt_sym = from_str $ to_str $sym_dict
assert_eq $rt_sym["name"] "alice"

# Nested structures
let nested =
  service:
    host: localhost
    ports:
      - 80
      - 443
let rt_nested = from_str $ to_str $nested
assert_eq $rt_nested["service"]["host"] "localhost"
assert_eq $rt_nested["service"]["ports"] [80, 443]

# Error cases
assert_err_contains "nil values are not TOML-representable" do to_str nil
assert_err_contains "TOML table keys must be str or sym values" do to_str {1: "bad"}
assert_err_contains "binary values are not TOML-representable" do to_str $ b"\x01\x02"
assert_err_contains "unsupported TOML type" do to_str $ range 10
assert_err_contains "TOML datetimes are not supported" do from_str "when = 1979-05-27T07:32:00Z"
assert_err_contains "cyclic reference" do
  let arr = []
  arr.push $arr
  to_str $arr
assert_err_contains "expected" do from_str "{ a = "
