import sqlite
import agent:
  - with_and_without_agent
import fs:
  - with_temp_dir
import strand:
  - fork

let STRAND_COUNT = 16
let INSERTS_PER_STRAND = 8

with_and_without_agent "wal" do
  with_temp_dir do |dir|
    sqlite.open (dir / "test.db") do |conn|
      conn.execute "PRAGMA journal_mode=WAL"
      conn.execute "CREATE TABLE test (id INTEGER PRIMARY KEY, value INTEGER)"

      # Concurrent writers plus a concurrent reader.
      # The reader exercises the WAL shared-memory path (shm_map/shm_lock)
      # alongside active writers; in WAL mode reads must never block writes.
      fork
        for i = range $STRAND_COUNT
          do sqlite.open (dir / "test.db") retries: 20 min_wait: 2 do |wconn|
            wconn.prepare "INSERT INTO test (value) VALUES (:value)" do |stmt|
              for j = range $INSERTS_PER_STRAND
                stmt.execute value: (i * INSERTS_PER_STRAND + j)
        - do sqlite.open (dir / "test.db") retries: 20 min_wait: 2 do |rconn|
            rconn.prepare "SELECT COUNT(*) AS cnt FROM test" do |stmt|
              for _ = range 5
                # Any consistent count in [0, total] is valid; just verify
                # the read doesn't error or block while writers are active.
                let rows = [...stmt.query()]
                assert (rows[0]["cnt"] >= 0)

      let total = (STRAND_COUNT * INSERTS_PER_STRAND)

      # All rows must be visible once all strands have completed.
      conn.prepare "SELECT COUNT(*) AS cnt FROM test" do |stmt|
        let rows = [...stmt.query()]
        assert_eq $rows[0]["cnt"] $total

      # Checkpoint the WAL; errors here would indicate a locking bug.
      conn.execute "PRAGMA wal_checkpoint(TRUNCATE)"

      # Data must still be fully readable after the checkpoint.
      conn.prepare "SELECT COUNT(*) AS cnt FROM test" do |stmt|
        let rows = [...stmt.query()]
        assert_eq $rows[0]["cnt"] $total
