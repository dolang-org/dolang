import sqlite
import std:
  - UnexpectedKeyError

# Test that exhaustive unpack fails when not all columns are consumed
sqlite.open ":memory:" do |conn|
  # Create table with multiple columns
  conn.execute "CREATE TABLE test (id INTEGER PRIMARY KEY, name TEXT, value REAL)"

  # Insert a row
  conn.execute "INSERT INTO test VALUES (1, 'test', 3.14)"

  # Query and get a row
  conn.prepare "SELECT * FROM test" do |stmt|
    for row = stmt.query()
      # Try to unpack exhaustively with only some columns
      # This should fail because we don't unpack all columns
      let success = try
        # Attempt exhaustive unpack
        let id: _ = row
        true
      catch UnexpectedKeyError: _
        false

      assert_not $success

# Test that partial unpack + rest iteration doesn't repeat columns
sqlite.open ":memory:" do |conn|
  # Create table with 4 columns
  conn.execute "CREATE TABLE test (a INTEGER, b TEXT, c REAL, d INTEGER)"

  # Insert data
  conn.execute "INSERT INTO test VALUES (1, 'two', 3.0, 4)"

  # Query and get row
  conn.prepare "SELECT * FROM test" do |stmt|
    for row = stmt.query()
      # Unpack 'a', get rest as iterator
      let :a ...rest = row
      assert_eq $a 1

      # Collect remaining values via iteration
      let remaining = [...rest]

      # Should have 3 values: b, c, d (not a)
      assert_eq $remaining.len 3

      # Check that we don't have 'a' (value 1) in remaining
      assert_not (remaining.contains 1)

# Test that unpacking from RowIter also doesn't repeat
sqlite.open ":memory:" do |conn|
  conn.execute "CREATE TABLE test (x INTEGER, y TEXT, z REAL)"

  conn.execute "INSERT INTO test VALUES (10, 'twenty', 30.0)"

  conn.prepare "SELECT * FROM test" do |stmt|
    for row = stmt.query()
      # Unpack x, get rest
      let :x ...rest = row
      assert_eq $x 10

      # Unpack y from rest
      let :y ...rest = rest
      assert_eq $y "twenty"

      # Now iterate rest - should only give us z
      let remaining = [...rest]

      # Should only have 1 value: z
      assert_eq $remaining.len 1
      assert_eq $remaining[0] 30.0
