import sqlite
import agent:
  - with_and_without_agent
import fs:
  - with_temp_dir
import strand:
  - fork

let STRAND_COUNT = 4
let INSERTS_PER_STRAND = 4

with_and_without_agent "concurrent" do
  with_temp_dir do |dir|
    sqlite.open (dir / "test.db") do |conn|
      # Create table
      conn.execute "CREATE TABLE test (id INTEGER PRIMARY KEY, value INTEGER)"

      # Unleash the fury
      fork
        for i = range $STRAND_COUNT
          do sqlite.open (dir / "test.db") retries: 20 min_wait: 2 do |conn|
            conn.prepare "INSERT INTO test (value) VALUES (:value)" do |stmt|
              for j = range $INSERTS_PER_STRAND
                stmt.execute value: (i * INSERTS_PER_STRAND + j)

      # Verify all insertions made it
      conn.prepare "SELECT value FROM test" do |stmt|
        let rows = [...stmt.query()]
        assert_eq $rows.len (STRAND_COUNT * INSERTS_PER_STRAND)
