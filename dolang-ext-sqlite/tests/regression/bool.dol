import sqlite

# BOOLEAN declared type returns bool values; plain INTEGER returns int
sqlite.open ":memory:" do |conn|
  conn.execute
    "CREATE TABLE test (id INTEGER PRIMARY KEY, flag BOOLEAN, count INTEGER)"

  # Bind true/false directly
  conn.prepare "INSERT INTO test (flag, count) VALUES (:flag, :count)" do |stmt|
    stmt.execute flag: true count: 42
    stmt.execute flag: false count: 0

  conn.prepare "SELECT flag, count FROM test ORDER BY id" do |stmt|
    let rows = [...stmt.query()]

    # BOOLEAN column comes back as bool
    assert (type rows[0]["flag"] bool)
    assert_eq $rows[0]["flag"] true

    assert (type rows[1]["flag"] bool)
    assert_eq $rows[1]["flag"] false

    # Plain INTEGER column still comes back as int
    assert (type rows[0]["count"] int)
    assert_eq $rows[0]["count"] 42

# Non-zero integer stored in BOOLEAN column is truthy (not just 1)
sqlite.open ":memory:" do |conn|
  conn.execute "CREATE TABLE t (v BOOLEAN)"
  conn.execute "INSERT INTO t VALUES (2)"

  conn.prepare "SELECT v FROM t" do |stmt|
    for row = stmt.query()
      assert (type row["v"] bool)
      assert_eq $row["v"] true

# BOOLEAN column is correctly unpacked by name
sqlite.open ":memory:" do |conn|
  conn.execute "CREATE TABLE t (name TEXT, active BOOLEAN)"
  conn.execute "INSERT INTO t VALUES ('Alice', 1)"
  conn.execute "INSERT INTO t VALUES ('Bob', 0)"

  conn.prepare "SELECT name, active FROM t ORDER BY name" do |stmt|
    for row = stmt.query()
      let :name :active = row
      if (name == "Alice")
        assert_eq $active true
      else
        assert_eq $active false
