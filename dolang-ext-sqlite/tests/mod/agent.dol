import
  strand:
    - pipeline
  proc.run:
    - cargo
  - sys
  - fs

let agent_bin = "../target/debug/dolang-shell-vfs"

let Vfs = nil
if (sys.os().archetype != :windows:)
  import shell:
    Vfs: it
  Vfs = it

  cd ../ $env RUSTFLAGS: nil $cargo -q build --bin dolang-shell-vfs

pub def with_agent block
  fs.with_temp_dir do |dir|
    dir.chmod 0o700
    let socket = (dir / "socket")

    pipeline
      do run $agent_bin $socket
      do
        strand.next()
        let agent = Vfs unix_socket: $socket
        return agent $block

pub def with_and_without_agent test block
  log "$test: without agent"
  block()
  if (sys.os().archetype != :windows:)
      log "$test: with agent"
      with_agent $block
