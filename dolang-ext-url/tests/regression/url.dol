import std:
  - hash
import url:
  - Url

let parsed = Url "https://user:pass@example.com:8443/a%20b/c?x=1&x=2&empty=&space=hello+world#frag"

assert_eq $parsed.scheme "https"
assert_eq $parsed.username "user"
assert_eq $parsed.password "pass"
assert_eq $parsed.host "example.com"
assert_eq $parsed.port 8443
assert_eq $parsed.path "/a%20b/c"
assert_eq $parsed.name "c"
assert_eq $parsed.fragment "frag"
assert_eq $parsed.query_raw "x=1&x=2&empty=&space=hello+world"
assert_eq [...parsed.segments()] ["a b", "c"]
let query1 = [...parsed.query()]
assert_eq $query1.len 4
assert_eq $query1[0][0] "x"
assert_eq $query1[0][1] "1"
assert_eq $query1[1][0] "x"
assert_eq $query1[1][1] "2"
assert_eq $query1[2][0] "empty"
assert_eq $query1[2][1] ""
assert_eq $query1[3][0] "space"
assert_eq $query1[3][1] "hello world"

let query2 = [...parsed.query()]
assert_eq $query2.len 4
assert_eq $query2[0][0] "x"
assert_eq $query2[3][1] "hello world"

let rebuilt = parsed.with_query [["q", "a b"], ["slash", "a/b"]]
assert_eq $rebuilt.query_raw "q=a+b&slash=a%2Fb"

let no_query = parsed.with_query_raw nil
assert_eq $no_query.query_raw nil

let no_fragment = parsed.with_fragment nil
assert_eq $no_fragment.fragment nil

let encoded = (Url "https://example.com" / "a b" / "c/d")
assert_eq $encoded.path "/a%20b/c%2Fd"
assert_eq $encoded.name "c/d"
assert_eq [...encoded.segments()] ["a b", "c/d"]

let href_base = Url "https://user:pass@example.com:8443/old/path?old=1#old"
let href = (href_base / "/new/path?x=1#frag")
assert_eq (str href) "https://user:pass@example.com:8443/new/path?x=1#frag"
assert_eq $href.name "path"

let bare = Url "https://example.com"
assert_eq $bare.name nil

let dir = Url "https://example.com/dir/"
assert_eq $dir.name nil

let eq1 = Url "https://example.com/a?x=1#frag"
let eq2 = Url "https://example.com/a?x=1#frag"
let eq3 = Url "https://example.com/b?x=1#frag"

assert_eq $eq1 $eq2
assert_ne $eq1 $eq3
assert_eq (hash eq1) (hash eq2)
assert_ne (hash eq1) (hash eq3)
assert (eq1 < eq3)
assert (eq3 > eq1)

let d = {}
d[eq1] = "value"
assert_eq $d[eq2] "value"
