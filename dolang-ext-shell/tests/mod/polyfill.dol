import sys

pub let echo = nil
pub let grep = nil
pub let cat = nil

if (sys.os == "windows")
  let cmd = run.cmd
  cat = do |...args| for arg = args.pos()
    cmd /c type $arg
  echo = do |...args| if (args.len == 0)
    cmd /c echo.
  else
    cmd /c echo ...args
  grep = do |...args| cmd /c findstr ...args
else
  cat = run.cat
  echo = run.echo
  grep = run.grep
