import
  strand:
    - pipeline
  - sys
  - fs

let agent_bin = nil
let Vfs = nil

if (sys.os != "windows")
  import container:
    Vfs: it
  Vfs = it
  agent_bin = env.get DOLANG_SHELL_VFS
  if !agent_bin
    throw "couldn't find dolang-shell-vfs in DOLANG_SHELL_VFS"

pub def with_agent block
  fs.with_temp_dir do |dir|
    dir.chmod 0o700
    let socket = (dir / "socket")

    pipeline
      do run $agent_bin $socket
      do
        strand.next()
        let agent = Vfs unix_socket: $socket
        return agent $block

pub def with_and_without_agent test block
  log "$test: without agent"
  block()
  if (sys.os != "windows")
      log "$test: with agent"
      with_agent $block
