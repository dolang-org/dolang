import std:
  - CanceledError
  - TimedOutError
import strand
import time:
  - sleep
  - timeout

assert_eq (timeout 0 do :expected:) :expected:

let timed_out = try
  timeout 0.01 do
    sleep 10000
    false
catch TimedOutError: _
  true
assert $timed_out

let res = timeout 0.1 do
  sleep 0
  :expected:
assert_eq $res :expected:

let cleaned = false
let inner = try
  timeout 0.1 do
    let value = try
      timeout 0 do
        sleep 10000
        :unexpected:
    catch TimedOutError: _
      :expected:
    sleep 0
    value
finally
  sleep 0
  cleaned = true
assert_eq $inner :expected:
assert $cleaned

let canceled = try
  let worker = strand.spawn do
    timeout 1 do
      sleep 10
  worker.cancel()
  worker.join()
  false
catch CanceledError: _
  true
assert $canceled
