import fs:
  - open
  - move
  - create_dir
  - with_temp_dir

import agent:
  - with_and_without_agent

with_and_without_agent "move file" do with_temp_dir do |dir|
  let src = (dir / "source.txt")
  let dst = (dir / "dest.txt")

  open $src w do |f|
    f.write "hello move"

  move $src $dst

  assert !$src.exists()
  open $dst r do |f|
    assert_eq (f.read()) "hello move"

with_and_without_agent "move directory requires all" do with_temp_dir do |dir|
  let src = (dir / "src")
  create_dir $src
  let dst = (dir / "dst")

  let res = try
    move $src $dst
    false
  catch _
    true
  assert $res

with_and_without_agent "move directory with all" do with_temp_dir do |dir|
  let src = (dir / "src")
  let nested = (src / "nested")
  create_dir $nested all: true

  open (nested / "file.txt") w do |f|
    f.write "nested move"

  let dst = (dir / "dst")
  move $src $dst all: true

  assert !$src.exists()
  open (dst / "nested" / "file.txt") r do |f|
    assert_eq (f.read()) "nested move"

with_and_without_agent "Path.move method" do with_temp_dir do |dir|
  let src = (dir / "source.txt")
  let dst = (dir / "dest.txt")

  open $src w do |f|
    f.write "method move"

  src.move $dst

  assert !$src.exists()
  open $dst r do |f|
    assert_eq (f.read()) "method move"
