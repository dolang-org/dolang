import fs:
  - open
  - remove
  - write

import agent:
  - with_and_without_agent
import std:
  - MissingPosError
  - UnexpectedKeyError

def assert_err_type ty block
  let res = try
    block()
    false
  catch e
    assert_eq (type e) $ty
    true
  assert $res

with_and_without_agent "seek and tell" do
  let path = "test_fs_seek.bin"
  let data = b"abcdef"
  write $path $data
  open $path "rb" do |file|
    assert_eq (file.tell()) 0
    assert_eq (file.seek 2) 2
    assert_eq (file.tell()) 2
    assert_eq (file.seek (0 - 1)) 1
    assert_eq (file.tell()) 1
    assert_eq (file.seek start: 4) 4
    assert_eq (file.tell()) 4
    assert_eq (file.seek end: (0 - 1)) 5
    assert_eq (file.tell()) 5
  remove $path

with_and_without_agent "seek clears buffered text reads" do
  let path = "test_fs_seek.txt"
  write $path "alpha\nbeta\n"
  open $path "r" do |file|
    assert_eq (file.next()) "alpha"
    assert_eq (file.seek start: 0) 0
    assert_eq (file.next()) "alpha"
  remove $path

with_and_without_agent "seek rejects redundant args" do
  let path = "test_fs_seek_args.txt"
  write $path "abc"
  open $path "r" do |file|
    assert_err_type $UnexpectedKeyError do file.seek 1 start: 2
    assert_err_type $UnexpectedKeyError do file.seek start: 1 end: 2
    assert_err_type $MissingPosError do file.seek()
  remove $path
