import sys

import
  fs:
    - Attrs
    - Metadata
    - Path
    - attrs
    - metadata
    - open
    - remove
    - set_attrs
  agent:
    - with_and_without_agent
  time:
    - DateTime

with_and_without_agent "file metadata basic" do
  let test_path = "test_metadata.txt"

  # Create test file with some content
  open $test_path w do |f|
    f.write "hello world"

  # Get metadata
  open $test_path r do |f|
    let meta = f.metadata()
    assert (type meta Metadata)
    assert_eq $meta.len 11
    assert_eq $meta.type :file:
    assert (type meta.modified DateTime)
    assert (meta.modified.unix_secs > 0.0)

  # Cleanup
  remove $test_path

with_and_without_agent "metadata timestamps" do
  let test_path = "test_metadata_time.txt"

  # Create test file
  open $test_path w do |f|
    f.write "timestamp test"

  # Get metadata
  open $test_path r do |f|
    let meta = f.metadata()
    assert (type meta Metadata)
    let modified = meta.modified
    assert (type modified DateTime)
    assert (modified.unix_secs > 0.0)  # positive timestamp

  # Cleanup
  remove $test_path

with_and_without_agent "metadata on closed file fails" do
  let test_path = "test_metadata_closed.txt"

  open $test_path w do |f|
    f.write "test content"
    f.close()
    let caught = try
      f.metadata()
      false
    catch _err
      true
    assert $caught

  remove $test_path

with_and_without_agent "metadata Unix fields" do
  if (sys.os_info().family != :windows:)
    let test_path = "test_metadata_unix.txt"

    open $test_path w do |f|
      f.write "unix metadata test"

    open $test_path r do |f|
      let meta = f.metadata()
      assert (type meta Metadata)
      assert (meta.mode > 0)
      assert (meta.dev >= 0)
      assert (meta.ino >= 0)
      assert (meta.nlink >= 1)
      assert (meta.uid >= 0)
      assert (meta.gid >= 0)
      assert (meta.rdev >= 0)
      assert (meta.blksize >= 0)
      assert (meta.blocks >= 0)

    remove $test_path
  else
    log "skipping Unix-specific test on Windows"

with_and_without_agent "metadata Windows attributes" do
  if (sys.os_info().family == :windows:)
    let test_path = "test_metadata_windows.txt"

    open $test_path w do |f|
      f.write "windows metadata test"

    open $test_path r do |f|
      let meta = f.metadata()
      assert (type meta Metadata)
      assert (type meta.win_attrs int)
      assert (type meta.attrs Attrs)
      assert (type meta.attrs.win_attrs int)
      assert (type meta.attrs.readonly bool)
      assert (type meta.attrs.hidden bool)
      assert (type meta.attrs.system bool)
      assert (type meta.attrs.archive bool)
      assert (type meta.attrs.reparse_point bool)
      assert (type meta.attrs.compressed bool)
      assert (type meta.attrs.encrypted bool)
      assert (type meta.attrs.temporary bool)
      assert (type meta.attrs.offline bool)
      assert (type meta.attrs.not_content_indexed bool)

    let direct_attrs = attrs $test_path
    let path_attrs = Path(test_path).attrs()
    assert (type direct_attrs Attrs)
    assert_eq $direct_attrs.win_attrs $path_attrs.win_attrs

    set_attrs $test_path readonly: true
    let readonly_attrs = attrs $test_path
    assert_eq $readonly_attrs.readonly true
    Path(test_path).set_attrs readonly: false
    let writable_attrs = Path(test_path).attrs()
    assert_eq $writable_attrs.readonly false

    if !sys.os_info().is_wine
      set_attrs $test_path compressed: true
      let compressed_attrs = attrs $test_path
      assert_eq $compressed_attrs.compressed true
      Path(test_path).set_attrs compressed: false
      let uncompressed_attrs = Path(test_path).attrs()
      assert_eq $uncompressed_attrs.compressed false
    else
      log "skipping Windows compression test under Wine"

    remove $test_path
  else
    log "skipping Windows-specific test on non-Windows"

with_and_without_agent "metadata Linux attributes" do
  if (sys.os_info().os == :linux:)
    let test_path = "test_metadata_linux_attrs.txt"
    open $test_path w do |f|
      f.write "linux attrs test"

    let direct_attrs = attrs $test_path
    assert (type direct_attrs Attrs)
    assert (type direct_attrs.unix_flags int)
    assert (type direct_attrs.immutable bool)
    assert (type direct_attrs.append_only bool)
    assert (type direct_attrs.no_dump bool)
    assert (type direct_attrs.no_atime bool)
    assert (type direct_attrs.no_copy_on_write bool)
    assert (type direct_attrs.dir_sync bool)
    assert (type direct_attrs.casefold bool)
    assert (type direct_attrs.data_journaling bool)
    assert (type direct_attrs.no_compress bool)
    assert (type direct_attrs.project_inherit bool)
    assert (type direct_attrs.secure_delete bool)
    assert (type direct_attrs.sync bool)
    assert (type direct_attrs.no_tail_merge bool)
    assert (type direct_attrs.top_dir bool)
    assert (type direct_attrs.undelete bool)
    assert (type direct_attrs.direct_access bool)
    assert (type direct_attrs.extent_format bool)

    set_attrs $test_path no_dump: true
    let no_dump_attrs = attrs $test_path
    assert_eq $no_dump_attrs.no_dump true
    Path(test_path).set_attrs no_dump: false
    let normal_attrs = Path(test_path).attrs()
    assert_eq $normal_attrs.no_dump false

    remove $test_path
  else
    log "skipping Linux-specific test on non-Linux"

with_and_without_agent "metadata macOS attributes" do
  if (sys.os_info().os == :macos:)
    let test_path = "test_metadata_macos_attrs.txt"
    open $test_path w do |f|
      f.write "macos attrs test"

    let meta = metadata $test_path
    assert (type meta Metadata)
    assert (type meta.unix_flags int)
    assert (type meta.attrs Attrs)
    assert (type meta.attrs.unix_flags int)
    assert (type meta.attrs.hidden bool)
    assert (type meta.attrs.compressed bool)
    assert (type meta.attrs.immutable bool)
    assert (type meta.attrs.append_only bool)
    assert (type meta.attrs.no_dump bool)
    assert (type meta.attrs.opaque bool)

    set_attrs $test_path hidden: true no_dump: true
    let hidden_attrs = attrs $test_path
    assert_eq $hidden_attrs.hidden true
    assert_eq $hidden_attrs.no_dump true
    Path(test_path).set_attrs hidden: false no_dump: false
    let normal_attrs = Path(test_path).attrs()
    assert_eq $normal_attrs.hidden false
    assert_eq $normal_attrs.no_dump false

    remove $test_path
  else
    log "skipping macOS-specific test on non-macOS"

with_and_without_agent "attrs unsupported on other platforms" do
  if !(sys.os_info().family == :windows: || sys.os_info().os == :linux: || sys.os_info().os == :macos:)
    let test_path = "test_attrs_unsupported.txt"
    open $test_path w do |f|
      f.write "attrs unsupported test"

    let get_failed = try
      attrs $test_path
      false
    catch _err
      true
    assert $get_failed

    let set_failed = try
      set_attrs $test_path readonly: true
      false
    catch _err
      true
    assert $set_failed

    remove $test_path
  else
    log "skipping attrs unsupported test on supported platform"

with_and_without_agent "metadata len and type" do
  # Test metadata returns correct len and type for a file
  let test_path = "test_metadata_len.txt"

  open $test_path w do |f|
    f.write "test"

  open $test_path r do |f|
    let meta = f.metadata()
    assert (type meta Metadata)
    assert_eq $meta.len 4
    assert_eq $meta.type :file:

  remove $test_path
