import fs:
  - hard_link
  - open
  - with_temp_dir

import agent:
  - with_and_without_agent

import sys

with_and_without_agent "fs.hard_link creates linked file" do with_temp_dir do |dir|
  let target = (dir / "target.txt")
  let link = (dir / "link.txt")

  open $target w do |f|
    f.write "hello"

  hard_link $target $link

  open $link r do |f|
    assert_eq (f.read()) "hello"

  if (sys.os_info().family != :windows:)
    assert (target.metadata().nlink >= 2)
    assert (link.metadata().nlink >= 2)

with_and_without_agent "Path.hard_link creates linked file" do with_temp_dir do |dir|
  let target = (dir / "target.txt")
  let link = (dir / "link.txt")

  open $target w do |f|
    f.write "hello"

  target.hard_link $link

  open $link r do |f|
    assert_eq (f.read()) "hello"

with_and_without_agent "hard_link missing source fails" do with_temp_dir do |dir|
  let target = (dir / "missing.txt")
  let link = (dir / "link.txt")

  let caught = try
    hard_link $target $link
    false
  catch _
    true

  assert $caught
