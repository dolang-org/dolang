import fs:
  - create_dir
  - remove_dir
  - open
  - with_temp_dir

import agent:
  - with_and_without_agent

with_and_without_agent "remove_dir removes empty directory" do with_temp_dir do |dir|
  let to_remove = (dir / "to_remove")

  create_dir $to_remove
  assert $to_remove.exists()

  remove_dir $to_remove
  assert $!to_remove.exists()

with_and_without_agent "remove_dir fails on non-empty directory" do with_temp_dir do |dir|
  let parent = (dir / "parent")
  let child = (parent / "file.txt")

  create_dir $parent
  open $child w do |f|
    f.write "content"

  # Should fail because directory is not empty
  let res = try
    remove_dir $parent
    false
  catch _
    true
  assert $res

  # Directory should still exist
  assert $parent.exists()

with_and_without_agent "remove_dir all removes empty directory tree" do with_temp_dir do |dir|
  let parent = (dir / "parent")
  let child_dir = (parent / "child" / "grandchild")

  create_dir $child_dir all: true

  assert $parent.exists()
  assert $child_dir.exists()

  remove_dir $parent all: true

  assert $!parent.exists()

with_and_without_agent "remove_dir ignores missing directory when requested" do with_temp_dir do |dir|
  let nonexistent = (dir / "does_not_exist")
  remove_dir $nonexistent ignore: true

with_and_without_agent "remove_dir free function is variadic" do with_temp_dir do |dir|
  let first = (dir / "first")
  let second = (dir / "second")
  first.create_dir()
  second.create_dir()
  remove_dir $first $second
  assert $!first.exists()
  assert $!second.exists()

with_and_without_agent "Path.remove_dir method" do with_temp_dir do |dir|
  let path = (dir / "method_remove")

  path.create_dir()
  assert $path.exists()

  path.remove_dir()
  assert $!path.exists()

with_and_without_agent "remove_dir all fails when tree contains files" do with_temp_dir do |dir|
  let parent = (dir / "parent")
  let child = (parent / "child")
  let file = (parent / "file.txt")

  child.create_dir all: true
  file.write "test"

  let res = try
    remove_dir $parent all: true
    false
  catch _
    true
  assert $res

  assert $parent.exists()
  assert $file.exists()

with_and_without_agent "remove_dir all ignore prunes only empty branches" do with_temp_dir do |dir|
  let parent = (dir / "parent")
  let keep = (parent / "keep")
  let keep_child = (keep / "child")
  let prune = (parent / "prune")
  let prune_child = (prune / "child")

  prune_child.create_dir all: true
  keep_child.create_dir all: true
  open (keep / "file.txt") w do |f|
    f.write "keep me"

  remove_dir $parent all: true ignore: true

  assert $parent.exists()
  assert $keep.exists()
  assert $!keep_child.exists()
  assert $!prune.exists()

with_and_without_agent "Path.remove_dir all" do with_temp_dir do |dir|
  let parent = (dir / "rmdir_all_test")
  let child = (parent / "child")

  child.create_dir all: true

  assert $parent.exists()

  parent.remove_dir all: true

  assert $!parent.exists()

with_and_without_agent "Path.remove_dir ignore" do with_temp_dir do |dir|
  let path = (dir / "missing")
  path.remove_dir ignore: true

with_and_without_agent "remove_dir fails on non-existent directory" do with_temp_dir do |dir|
  let nonexistent = (dir / "does_not_exist")

  let res = try
    remove_dir $nonexistent
    false
  catch _
    true
  assert $res

with_and_without_agent "remove_dir fails on file" do with_temp_dir do |dir|
  let file_path = (dir / "a_file.txt")

  open $file_path w do |f|
    f.write "not a directory"

  let res = try
    remove_dir $file_path
    false
  catch _
    true
  assert $res

  # File should still exist
  assert $file_path.exists()
