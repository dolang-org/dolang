import fs:
  - DirEntry
  - entries
  - Path

import agent:
  - with_and_without_agent

with_and_without_agent "basic entries" do
  let count = 0
  for _ = entries src
    count = (count + 1)

  assert (count > 0)

with_and_without_agent "Path.entries" do
  let iter = Path("src").entries()
  let found_lib = false
  for entry = iter
    assert (type entry DirEntry)
    if (entry.path.name == "lib.rs")
      assert_eq $entry.name lib.rs
      found_lib = true
      break

  assert $found_lib
