import fs:
  - create_dir
  - open
  - read
  - write
  - remove
  - Path

import agent:
  - with_and_without_agent

with_and_without_agent "write and read back text" do
  # Test writing text and reading it back
  let test_path = "test_write_text.txt"

  # Write text to file
  open $test_path w do |f|
    let written = f.write "Hello, World!"
    assert_eq $written 13

  # Read it back
  open $test_path r do |f|
    let contents = f.read()
    assert_eq $contents "Hello, World!"

  # Cleanup
  remove $test_path

with_and_without_agent "write binary data" do
  # Test writing binary data using binary string literals
  let test_path = "test_write_binary.bin"
  let binary_data = b"Hello"

  # Write binary data
  open $test_path wb do |f|
    let written = f.write $binary_data
    assert (written > 0)

  # Read it back in binary mode
  open $test_path rb do |f|
    let contents = f.read()
    assert_eq $contents $binary_data

  # Cleanup
  remove $test_path

with_and_without_agent "write to file opened in append mode" do
  # Test appending to a file
  let test_path = "test_append.txt"

  # Write initial content
  open $test_path w do |f|
    f.write "First line"

  # Append more content
  open $test_path a do |f|
    let written = f.write "\nSecond line"
    assert (written > 0)

  # Read all content
  open $test_path r do |f|
    let contents = f.read()
    assert (contents.contains "First line")
    assert (contents.contains "Second line")

  # Cleanup
  remove $test_path

with_and_without_agent "write after close fails" do
  # Test that writing to a closed file fails
  let test_path = "test_write_closed.txt"

  open $test_path w do |f|
    f.close()
    let caught = try
      f.write "should fail"
      false  # Should not reach here
    catch _err
      true  # Expected to catch error
    assert $caught

  # Cleanup
  remove $test_path

with_and_without_agent "write non-string value" do
  # Test writing a non-string value (should convert to string)
  let test_path = "test_write_number.txt"

  open $test_path w do |f|
    let written = f.write 12345
    assert (written > 0)

  # Read it back
  open $test_path r do |f|
    let contents = f.read()
    assert_eq $contents "12345"

  # Cleanup
  remove $test_path

with_and_without_agent "remove file" do
  # Test removing a file
  let test_path = "test_remove.txt"

  # Create a file first
  open $test_path w do |f|
    f.write "delete me"

  # Remove the file
  remove $test_path

  # Verify file is gone by trying to read it (should fail)
  let caught = try
    open $test_path "r" do |_f|
      false  # Should not reach here
    false
  catch _err
    true  # Expected to catch error
  assert $caught

with_and_without_agent "remove non-existent file fails" do
  # Test that removing a non-existent file fails
  let test_path = "test_remove_nonexistent.txt"

  # Ensure file doesn't exist
  let caught = try
    remove $test_path
    false  # Should not reach here
  catch _err
    true  # Expected to catch error
  assert $caught

with_and_without_agent "remove ignores missing path when requested" do
  remove "test_remove_ignore.txt" ignore: true

with_and_without_agent "remove free function is variadic" do
  write "test_remove_first.txt" "a"
  write "test_remove_second.txt" "b"
  remove "test_remove_first.txt" "test_remove_second.txt"
  assert (!(Path "test_remove_first.txt").exists())
  assert (!(Path "test_remove_second.txt").exists())

with_and_without_agent "remove all removes directory trees" do
  create_dir "test_remove_all/subdir" all: true
  write "test_remove_all/subdir/file.txt" "hello"
  remove "test_remove_all" all: true
  assert (!(Path "test_remove_all").exists())

with_and_without_agent "fs.write writes and truncates text file" do
  let test_path = "test_fs_write_text.txt"
  assert_eq (write test_path "Hello from fs.write") 19
  assert_eq (read test_path) "Hello from fs.write"
  assert_eq (write (Path test_path) "short") 5
  assert_eq ((Path test_path).read()) "short"
  remove $test_path

with_and_without_agent "fs.write writes binary data" do
  let test_path = "test_fs_write_binary.bin"
  assert_eq (write test_path b"Hello") 5
  assert_eq ((Path test_path).read "b") b"Hello"
  remove $test_path

with_and_without_agent "Path.write stringifies non-binary values" do
  let test_path = Path "test_path_write_value.txt"
  assert_eq (test_path.write 12345) 5
  assert_eq (read test_path) "12345"
  remove $test_path

with_and_without_agent "Path.remove supports all and ignore" do
  let dir = Path "test_path_remove"
  (dir / "nested").create_dir all: true
  write (dir / "nested" / "file.txt") "payload"
  dir.remove all: true
  assert (!dir.exists())
  dir.remove ignore: true
