import fs:
  - open

import agent:
  - with_and_without_agent

with_and_without_agent "basic open" do
  # Test basic open without block
  let f = open "Cargo.toml" "r"
  let debug_str = dbg $f
  assert_eq $debug_str "<fs.File>"
  f.close()

with_and_without_agent "block scope" do
  # Test block scope syntax
  let result = open "Cargo.toml" "r" do |file|
    let s = dbg $file
    assert_eq $s "<fs.File>"
    "success"
  assert_eq $result "success"
