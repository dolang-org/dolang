import fs:
  - open
  - symlink
  - symlink_dir
  - symlink_file
  - create_dir
  - with_temp_dir

import agent:
  - with_and_without_agent

with_and_without_agent "symlink file" do with_temp_dir do |dir|
  let target = (dir / "target.txt")
  let link = (dir / "link.txt")

  # Create target file
  open $target w do |f|
    f.write "symlink target"

  # Create symlink
  symlink $target $link

  # Verify symlink exists and points to target
  assert $link.exists()

  # Read through symlink
  open $link r do |f|
    let contents = f.read()
    assert_eq $contents "symlink target"

  # Verify read_link works
  let resolved = link.read_link()
  assert_eq $resolved $target

with_and_without_agent "symlink_dir creates directory symlink" do with_temp_dir do |dir|
  let target = (dir / "target_dir")
  let link = (dir / "link_dir")

  # Create target directory with file
  create_dir $target
  open (target / "file.txt") w do |f|
    f.write "in target dir"

  # Create directory symlink
  symlink_dir $target $link

  # Verify symlink exists
  assert $link.exists()

  # Access file through symlink
  open (link / "file.txt") r do |f|
    let contents = f.read()
    assert_eq $contents "in target dir"

with_and_without_agent "symlink_file creates file symlink" do with_temp_dir do |dir|
  let target = (dir / "target.txt")
  let link = (dir / "link.txt")

  open $target w do |f|
    f.write "file target"

  symlink_file $target $link

  assert $link.exists()
  open $link r do |f|
    let contents = f.read()
    assert_eq $contents "file target"

with_and_without_agent "symlink metadata follows by default" do with_temp_dir do |dir|
  let target = (dir / "target.txt")
  let link = (dir / "link.txt")

  open $target w do |f|
    f.write "test"

  symlink $target $link

  # Default metadata follows symlink
  let meta = link.metadata()
  assert_eq $meta.type :file:

with_and_without_agent "symlink metadata nofollow" do with_temp_dir do |dir|
  let target = (dir / "target.txt")
  let link = (dir / "link.txt")

  open $target w do |f|
    f.write "test"

  symlink $target $link

  # Metadata with follow=false
  let meta = link.metadata(false)
  assert_eq $meta.type :symlink:

with_and_without_agent "broken symlink" do with_temp_dir do |dir|
  let target = (dir / "nonexistent.txt")
  let link = (dir / "broken_link.txt")

  # Create symlink to non-existent target
  symlink_file $target $link

  # Symlink exists but target does not
  assert !$target.exists()
  # The symlink itself exists as a file system entry
  # Note: exists() may or may not follow symlinks depending on implementation

  # read_link should still work on broken symlink
  let resolved = link.read_link()
  assert_eq $resolved $target
