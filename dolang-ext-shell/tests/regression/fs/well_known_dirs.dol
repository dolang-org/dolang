import
  agent:
    - with_and_without_agent
  fs:
    - Path
  - fs
  - sys

with_and_without_agent "fs.home_dir and fs.cache_dir return absolute paths" do
  assert $fs.home_dir().is_absolute
  assert $fs.cache_dir().is_absolute

with_and_without_agent "fs.home_dir respects scoped HOME on Unix" do
  if (sys.os().archetype == :windows:)
    return

  env HOME: /tmp/dolang-home do
    assert_eq (fs.home_dir()) (Path "/tmp/dolang-home")

with_and_without_agent "fs.home_dir rejects relative HOME on Unix" do
  if (sys.os().archetype == :windows:)
    return

  let failed = try
    env HOME: relative-home do
      fs.home_dir()
    false
  catch sys.Error: _
    true

  assert $failed

with_and_without_agent "fs.cache_dir follows platform conventions" do
  if (sys.os().archetype == :windows:)
    return

  env HOME: /tmp/dolang-home XDG_CACHE_HOME: /tmp/dolang-cache do
    if (sys.os().kind == :macos:)
      assert_eq (fs.cache_dir()) (Path "/tmp/dolang-home/Library/Caches")
    else
      assert_eq (fs.cache_dir()) (Path "/tmp/dolang-cache")
