import sys
import std:
  - MissingPosError

if (sys.os == "windows")
  log "skipped on Windows"
  return

let baseline = {...env}
assert (baseline.contains "PATH")

env TEST_DOLANG_ENV_BASE: baseline TEST_DOLANG_ENV_OTHER: keep do
  env PATH: overlay TEST_DOLANG_ENV_ADDED: added TEST_DOLANG_ENV_BASE: nil do
    let snapshot = {...env}

    assert_eq $snapshot["PATH"] overlay
    assert_eq $snapshot["TEST_DOLANG_ENV_ADDED"] added
    assert_eq $snapshot["TEST_DOLANG_ENV_OTHER"] keep
    assert (!snapshot.contains "TEST_DOLANG_ENV_BASE")

    bind env
      first = "missing"
      ...
    assert_eq $first missing

    let required_pos_failed = try
      let _ ... = (env)
      false
    catch MissingPosError: _
      true
    assert $required_pos_failed

    let :PATH :TEST_DOLANG_ENV_ADDED ...rest = (env)
    assert_eq $PATH overlay
    assert_eq $TEST_DOLANG_ENV_ADDED added

    let :TEST_DOLANG_ENV_OTHER ...remaining = rest
    let remaining_map = {...remaining}
    assert_eq $TEST_DOLANG_ENV_OTHER keep
    assert (!remaining_map.contains "PATH")
    assert (!remaining_map.contains "TEST_DOLANG_ENV_ADDED")
    assert (!remaining_map.contains "TEST_DOLANG_ENV_BASE")
