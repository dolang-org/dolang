import strand:
 - pipeline
 - each
 - collect

import polyfill:
 - grep
 - cat

let res = pipeline
 do cat Cargo.toml
 do grep "\\[dependencies"
 do each do |line| line.trim_end "\r\n"
 do collect()

assert_eq $res $
  - "[dependencies]"
  - "[dependencies.tokio]"
  - "[dependencies.dolang]"
  - "[dependencies.dolang-shell-vfs]"
