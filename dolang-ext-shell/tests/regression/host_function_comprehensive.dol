import sys

if (sys.os().archetype == :windows:)
  log "skipped on Windows"
  return

import agent:
  - with_and_without_agent

import shell:
  - host

with_and_without_agent "host function resets context to defaults" do
  let original_cwd = cd()
  
  # Change directory
  cd /tmp
  let changed_cwd = cd()
  assert_eq (str changed_cwd) "/tmp"
  
  # Use host function to reset to defaults
  host do
    let reset_cwd = cd()
    # Should be back to original, not /tmp
    assert_eq $reset_cwd $original_cwd
  
  # Verify we're back to changed state
  let final_cwd = cd()
  assert_eq (str final_cwd) "/tmp"
  
  # Restore original directory
  cd $original_cwd
