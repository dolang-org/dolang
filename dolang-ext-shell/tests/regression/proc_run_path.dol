import sys
  agent:
    - with_and_without_agent

with_and_without_agent "proc.run accepts Path selectors" do
  let is_windows = (sys.os_info().family == :windows:)
  let name = if is_windows
    "cmd.exe"
  else
    "echo"
  let path = run[name].which()
  log "path: $path"
  let prog = run[path]
  if is_windows
    prog /c echo ok
    run $path /c echo ok
  else
    prog ok
    run $path ok
