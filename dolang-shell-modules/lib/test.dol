import args compile diagnostic load progress strand
  fs:
    - Path
  glob:
    - Glob
import time:
  - timeout

let collect_key = strand.Key()

pub def test func
  collect_key.value.push [str(func), func]

pub class Assert: std.RuntimeError
  pub let message = nil

  def (init) self message
    self.message = message

  def (str) self
    if (self.message != nil)
      "assertion failed: $(self.message)"
    else
      "assertion failed"

# Exception thrown to skip a test case.
#
# Throw this (or call `skip()`) from a test function to mark it as skipped
# rather than failed.
pub class Skip: std.RuntimeError
  # Skip message, or `nil` is none specified
  pub let message = nil

  def (init) self message = nil
    self.message = message

# Skip the current test with an optional message.
pub def skip msg = nil
  throw Skip $msg

# Assert that `cond` is truthy, throwing an error with optional `msg` on failure.
pub def assert cond msg = nil
  if !cond
    throw Assert $msg

# Assert that `cond` is falsy, throwing an error with optional `msg` on failure.
pub def assert_not cond msg = nil
  if !cond
    throw Assert $msg

# Assert that `left == right`, throwing an error with optional `msg` on failure.
pub def assert_eq left right msg = nil
  if (left != right)
    if msg
      throw Assert "$(dbg left) == $(dbg right): $msg"
    else
      throw Assert "$(dbg left) == $(dbg right)"

# Assert that `left != right`, throwing an error with optional `msg` on failure.
pub def assert_ne left right msg = nil
  if (left == right)
    if msg
      throw Assert "$(dbg left) != $(dbg right): $msg"
    else
      throw Assert "$(dbg left) != $(dbg right)"

def parse_jobs value
  let jobs = try
    int $value
  catch std.RuntimeError: _
    throw args.Error "--jobs expects an integer"
  if (jobs < 1)
    throw args.Error "--jobs must be at least 1"
  jobs

def parse_timeout value
  let secs = try
    float $value
  catch std.RuntimeError: _
    throw args.Error "--timeout expects a number"
  if !(secs >= 0)
    throw args.Error "--timeout must be non-negative"
  secs

class Harness
  let jobs = nil
  let filter = nil
  let timeout = nil
  let filter_glob = nil
  let errors = nil
  let success = 0
  let total = 0

  def (init) self :jobs :filter :timeout
    self.#jobs = jobs
    self.#timeout = timeout
    self.#errors = []
    self.#filter = try
        Glob $filter
    catch std.RuntimeError: _
        throw args.Error "invalid --filter glob: $filter"

  def matches_filter self path test
     self.#filter.matches $path.stem/$test


  def record_test self
    self.#total = (self.#total + 1)

  def record_success self
    self.#success = (self.#success + 1)

  def with_timeout self func
    if (self.#timeout != nil)
      timeout $self.#timeout $func
    else
      func()

  def record_error self err bt path test = nil
    self.#errors.push [err, bt, path, test]

  def run_test self path name func
    self.#record_test()
    try
      self.#with_timeout $func
      self.#record_success()
    catch std.RuntimeError: e
      self.#record_error $e $(strand.error_backtrace()) $path $name

  def run_module self path tests
    progress.show message: $path.stem total: $tests.len do |w|
      strand.fork limit: $self.#jobs
        for name func = tests
          do progress.show message: $name do |_|
            self.#run_test $path $name $func
            w.delta()

  def run_file self path
    let source = path.read b
    let compiled = compile.compile $path $source
    for diag = compiled.diagnostics
      diagnostic.print_compile_diag $diag
    if !compiled.ok
      throw std.CompileError "failed to compile $(path.relative())"

    collect_key.value = []
    self.#with_timeout do load.run $compiled.bytecode
    let tests = collect_key.value
    collect_key.value = nil
    self.#run_module $path $tests

  def report self
    let rc = 0
    for e bt path test = self.#errors
      if (type e Skip)
        if test
          if e.message
            echo "test skipped: $(path.stem)/$test ($(e.message))"
          else
            echo "test skipped: $(path.stem)/$test"
        else
          if e.message
            echo "module skipped: $(path.stem) ($(e.message))"
          else
            echo "module skipped: $(path.stem)"
      else
        rc = 1
        if test
          echo "test failed: $(path.stem)/$test"
        else
          echo "module failed: $(path.stem)"
        diagnostic.print_error $e backtrace: $bt
    echo "tests passed: $(self.#success)/$(self.#total)"
    rc

  pub def run self files
    progress.with do progress.show message: modules total: $files.len do |w|
      for path = files
        try
          self.#run_file $path
        catch std.RuntimeError: e
          self.#record_error $e $(strand.error_backtrace()) $path
        w.delta()
    self.#report()

pub def main()
  args.with
    help: Run Do unit test modules.
    - opt: jobs
      short: j
      type: $parse_jobs
      default: 8
      meta: N
      help: Max concurrent strands per module.
    - opt: filter
      default: **
      help: Glob filter for test names in `stem/test` form
    - opt: timeout
      type: $parse_timeout
      default: 600
      meta: SECS
      help: Max seconds for each test and module load.
    - arg: files
      type: $Path
      collect: true
      help: Test files to run.
    do |p|
      let :filter :jobs :timeout :files ... = p
      let harness = Harness :jobs :filter :timeout
      exit $ harness.run $files
