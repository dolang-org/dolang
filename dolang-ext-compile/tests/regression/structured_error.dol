import compile
import std:
  - hash

let result = compile.compile "bad.dol" "let =\n"
assert (!result.ok)
assert_eq $result.bytecode nil
assert (result.diagnostics.len > 0)

let diag = result.diagnostics[0]
assert (type diag compile.Diagnostic)
assert_eq $diag.severity :error:
assert (type diag.span compile.Span)
assert (type diag.span.start compile.Pos)
assert_eq $diag.span.start $diag.span.start
assert_eq (hash diag.span.start) (hash diag.span.start)
assert (diag.span.start <= diag.span.end)
assert_eq $diag.span $diag.span
assert_eq (hash diag.span) (hash diag.span)
assert (diag.span <= diag.span)
assert (type diag.annotations array)
assert (type diag.notes array)
assert (type diag.patches array)
