import sys admin
  fs:
    - Path
    - create_dir
    - remove
    - with_temp_dir
    - symlink_file

let MIRI_CRATES =
  - dolang-bytecode
  - dolang-compile
  - dolang-runtime
  - dolang-private-util
  - dolang
  - dolang-private-regression

let COV_IGNORE =
  - dolang-private-util/src/hashbrown
  - dolang-private-doc
  - dolang-private-highlight
  - dolang-private-build

let MKDOCS_BINS =
  - dolang-highlight
  - dolang-doc

let PUBLISH_CRATES =
  - dolang-private-build
  - dolang-private-bundle
  - dolang-private-util
  - dolang-rpc
  - dolang-bytecode
  - dolang-compile
  - dolang-runtime
  - dolang
  - dolang-private-test
  - dolang-shell-vfs
  - dolang-ext-compile
  - dolang-ext-json
  - dolang-ext-url
  - dolang-ext-regex
  - dolang-ext-glob
  - dolang-ext-base64
  - dolang-ext-digest
  - dolang-ext-rand
  - dolang-ext-xml
  - dolang-ext-yaml
  - dolang-ext-toml
  - dolang-ext-shell
  - dolang-ext-http
  - dolang-ext-zip
  - dolang-ext-sqlite
  - dolang-ext-progress
  - dolang-ext-load
  - dolang-shell-core
  - dolang-shell-modules
  - dolang-shell
  - dolang-lsp

let TARGETS =
  "x86_64-linux":
    tuple: x86_64-unknown-linux-gnu
  "x86_64-windows":
    if (sys.os_info().family == :WINDOWS:)
      # Native target
      tuple: x86_64-pc-windows-msvc
    else
      # Cross target
      tuple: x86_64-pc-windows-gnullvm
    exe: true
  "aarch64-macos":
    tuple: aarch64-apple-darwin

def default_target()
  let target = "$(str(sys.cpu_info().arch).lower())-$(str(sys.os_info().os).lower())"
  if !(TARGETS.contains target)
    throw "unsupported host target: $target"
  target

def show ...cmd
  echo "+" ...cmd
  run ...cmd

class Spec
  pub field target tuple profile channel target_dir
  field extra

  def (init)
    self args
    :profile = nil
    :variant = nil
    :tuple = nil
    :channel = nil
    :extra = []
  do
    self.target = TARGETS[args.target || default_target()]
    self.tuple = (tuple || self.target[:tuple:])
    self.profile = (profile || "debug")
    self.channel = channel
    self.#extra = extra
    self.target_dir = if variant
      (Path("target") / self.tuple / variant / self.profile)
    else
      (Path("target") / self.tuple / self.profile)

  pub def bin self name
    let exe = self.target.get :exe:
    let path = (self.target_dir / name).absolute()
    if exe
      path.add_ext exe
    else
      path

  pub def cargo self cmd ...rest
    show cargo
      if self.channel
        +$self.channel
      $cmd --target $self.tuple
      if (self.profile == "release")
        --$self.profile
      else if (self.profile != "debug")
        --profile $self.profile
      ...self.#extra ...rest

  pub def cargo_vfs self ...rest
    self.cargo build --bin dolang-shell-vfs
    self.cargo ...rest

def default_shell_tests()
  ["test"]

def mkdocs_build_tools spec
  spec.cargo build
    for bin = MKDOCS_BINS
      --bin $bin

def with_mkdocs spec func
  env
    DOLANG_HIGHLIGHT: $spec.bin("dolang-highlight")
    DOLANG_DOC: $spec.bin("dolang-doc")
    NO_MKDOCS_2_WARNING: 1
    $func

def cargo_test spec rest
  spec.cargo test ...rest

def shell_test spec tests
  spec.cargo_vfs run --bin dolang -- --module-path testlib -m test
    ...(tests || default_shell_tests())

def both_test spec
  cargo_test $spec []
  shell_test $spec nil

def can_write_dir path
  try
    create_dir $path all: true
    with_temp_dir parent: $path do |_| true
  catch sys.PermissionDeniedError: _
    false

def install_bin spec bin_dir name
  let bin = spec.bin(name)
  let dst = (bin_dir / bin.name).absolute()
  let tmp = dst.add_ext tmp
  bin.copy $tmp
  tmp.rename $dst
  echo "installed: $dst"

def install_bin_symlink spec bin_dir from to
  let bin = spec.bin(from)
  let src = (bin_dir / bin.name).absolute()
  let dst = src.with_stem $to
  let tmp = dst.add_ext tmp
  symlink_file (src.relative bin_dir) $tmp
  tmp.rename $dst
  echo "link: $dst -> $src"

return
  common:
    - opt: target
      help: target platform
      default: nil
      values: [...TARGETS.keys()]
  default: build

  "test-asan":
    help: run tests with AddressSanitizer
    - arg: args
      help: "arguments to nightly cargo build/test/run"
      collect: true
    do |args|
      let spec = Spec $args
        channel: nightly
        profile: asan
        extra:
          -Z build-std
      env RUSTFLAGS: "-Z sanitizer=address" do both_test $spec

  "test-miri":
    help: run tests with miri
    - arg: args
      help: arguments to `cargo +nightly miri test`
      collect: true
    do |args|
      env MIRIFLAGS: -Zmiri-disable-isolation do
        show cargo +nightly miri test
          for crate = MIRI_CRATES
            -p $crate
          ...args.args

  build:
    help: build main artifacts
    - arg: args
      help: arguments to `cargo build`
      collect: true
    do |args|
      let spec = Spec $args
      spec.cargo build ...args.args

  run:
    help: run dolang
    - arg: args
      help: additional arguments to dolang
      collect: true
    do |args|
      let spec = Spec $args
      spec.cargo_vfs run --bin dolang -- ...args.args

  "cargo-test":
    help: run cargo tests
    - arg: args
      help: "arguments to `cargo test`"
      collect: true
    do |args|
      cargo_test (Spec args) $args.args

  "gen-system-error-codes":
    help: generate system error code lookup tables from public source documents
    - arg: args
      help: source arguments for tools/gen_system_error_codes.py
      collect: true
    do |args|
      show python3 tools/gen_system_error_codes.py
        --output dolang-ext-shell/src/error_code/generated.rs
        ...args.args

  "shell-test":
    help: run shell integration tests
    - arg: args
      help: arguments to `dolang -m test` (default: $default_shell_tests())
      collect: true
    do |args|
      shell_test (Spec args) $args.args

  "test":
    help: run all tests
    do |args|
      both_test (Spec args)

  "gen-bytecode-fuzz-seeds":
    help: generate bytecode fuzz seeds
    do |_|
      run cargo run --bin gen-bytecode-seeds

  "fuzz-bytecode":
    help: run the bytecode fuzzer
    - arg: args
      help: "arguments to `cargo +nightly fuzz run`"
      collect: true
    do |args|
      dodo gen-bytecode-fuzz-seeds
      show cargo +nightly fuzz run bytecode_deserialize
        target/fuzz-corpus/bytecode_deserialize
        ...args.args

  "fuzz-bytecode-smoke":
    help: run a short bytecode fuzz smoke test
    do |_|
      dodo fuzz-bytecode -- -runs=1000 -max_len=1048576

  cov:
    help: run coverage collection
    do |args|
      let spec = Spec $args
        variant: llvm-cov-target
        extra:
          --all-features
      spec.cargo llvm-cov clean
      spec.cargo llvm-cov --no-report run --ignore-run-fail --bin dolang-shell-vfs
      env
        DO_EXPORT_DOT: $Path("dot").absolute()
        VFS: (spec.bin "dolang-shell-vfs")
        do
          spec.cargo llvm-cov --no-report test
          spec.cargo llvm-cov run --no-report --bin dolang --
            --module-path testlib -m test ...default_shell_tests()

  "cov-dump":
    help: write coverage summaries to disk
    do |args|
      let spec = Spec $args
      let ignore = "($("|".join COV_IGNORE))"
      spec.cargo llvm-cov report --json --summary-only --output-path cov.json
        --ignore-filename-regex $ignore
      spec.cargo llvm-cov report --json --output-path cov.full.json
        --ignore-filename-regex $ignore
      spec.cargo llvm-cov report --text --output-path cov.full.txt
        --ignore-filename-regex $ignore

  "serve-cov":
    help: build and serve the HTML coverage report
    do |args|
      let spec = Spec $args
      let ignore = "($("|".join COV_IGNORE))"
      spec.cargo llvm-cov report --html --ignore-filename-regex $ignore
      show python3 -m http.server 8080 -d target/llvm-cov/html/ -b localhost

  rustdoc:
    help: build selected rustdoc packages
    do |_|
      show cargo doc -p dolang-runtime -p dolang-compile -p dolang-ext-shell --no-deps

  "serve-rustdoc":
    help: build and serve rustdoc locally
    do |_|
      show cargo doc --package dolang --package dolang-ext-shell --no-deps
      show python3 -m http.server 8080 -d target/doc -b localhost

  "serve-mkdocs":
    help: build and serve the MkDocs site
    do |args|
      let spec = Spec $args profile: release
      mkdocs_build_tools $spec
      with_mkdocs $spec do show mkdocs serve

  mkdocs:
    help: build the MkDocs site
    do |args|
      let spec = Spec $args profile: release
      mkdocs_build_tools $spec
      with_mkdocs $spec do show mkdocs build

  fmt:
    help: format Rust and Markdown
    do |_|
      show cargo fmt
      show rumdl fmt

  lint:
    help: check for coding/formatting errors
    do |args|
      let spec = Spec $args
      spec.cargo clippy --all-targets
      show cargo fmt --check
      show rumdl check

  clean:
    help: remove build artifacts and generated docs
    do |_|
      show cargo clean
      remove site dot all: true ignore: true

  install:
    help: install dolang binaries
    - opt: prefix
      type: $Path
      help: installation root
    do |args|
      let spec = Spec $args profile: dist
      let is_linux = spec.tuple.ends_with "-linux-gnu"
      let vfs_spec = if is_linux
        Spec $args
          profile: dist
          tuple: $(spec.tuple.without_suffix "-gnu")-musl
      else
        spec

      env
        if is_linux
          ZSTD_SYS_USE_PKG_CONFIG: 1
        do
          spec.cargo build --bin dolang --bin dolang-lsp
          vfs_spec.cargo build --bin dolang-shell-vfs

      let bin_dir = (args.prefix / "bin")

      let context = if can_write_dir $bin_dir
        do |block| block()
      else
        admin.with

      context do
        create_dir $bin_dir all: true
        install_bin $spec $bin_dir dolang
        install_bin $spec $bin_dir dolang-lsp
        install_bin_symlink $spec $bin_dir dolang dodo
        install_bin_symlink $spec $bin_dir dolang dolang-test
        install_bin $vfs_spec $bin_dir dolang-shell-vfs

  publish:
    help: publish workspace crates in dependency order
    - arg: args
      help: "arguments to `cargo publish`"
      collect: true
    do |args|
      for crate = PUBLISH_CRATES
        show cargo publish -p $crate ...args.args
