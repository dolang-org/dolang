import test: unittest _vfs
  shell:
    - Vfs
  strand:
    - pipeline
  - sys
  - fs

let vfs_bin = _vfs.bin()

def with_vfs remote block
  if (sys.os_info().family == :WINDOWS:)
    let vfs = Vfs.windows_admin elevate: false remote: $remote
    try
      vfs $block
    finally
      vfs.stop()
  else if remote
    let vfs = Vfs do run $vfs_bin --stdio
    try
      vfs $block
    finally
      vfs.stop()
  else
    fs.with_temp_dir do |dir|
      dir.set_metadata mode: 0o700
      let socket = (dir / "socket")
      let input = strand.input()

      pipeline
        do run $vfs_bin $socket
        do
          strand.next()
          let vfs = Vfs.unix_socket $socket
          return strand.redirect input: $input do vfs $block

pub def test
  :name = nil
  :windows_vfs = true
  :remote = true
  func = nil
do
  if (func == nil)
    return do |func| test :name :windows_vfs :remote $func
  name = (name || str(func))
  # Wrap func to run in temp directory since it will likely create files
  let func = do fs.with_temp_dir do |dir| cd $dir $func
  if (sys.os_info().family == :WINDOWS: && !windows_vfs)
    unittest.test name: "$(name)/direct" $func
    unittest.test name: "$(name)/local" do unittest.skip "Windows functionality not ready"
    unittest.test name: "$(name)/remote" do unittest.skip "Windows functionality not ready"
    func
  else
    unittest.test name: "$(name)/local" do with_vfs false $func
    if remote
      unittest.test name: "$(name)/remote" do with_vfs true $func
    else
      unittest.test name: "$(name)/remote" do unittest.skip "remote functionality not ready"
    unittest.test name: "$(name)/direct" $func
    func
