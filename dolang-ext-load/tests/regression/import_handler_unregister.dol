import
  load
  std:
    - ImportError

let handle = load.import_handler do |name|
  if (name == "synthetic_unregister")
    record answer: 1
  else
    throw ImportError(name)

handle.unregister()

let ok = try
  import synthetic_unregister:
    - answer
  assert_eq $answer 1
  false
catch ImportError: err
  assert_eq (str err) "module not found: synthetic_unregister"
  true

assert $ok
