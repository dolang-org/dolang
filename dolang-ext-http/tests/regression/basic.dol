import http

http.get $TEST_URL/get do |res|
  assert_eq $res.status 200
  let body = res.text()
  assert (body.len > 0)

http.post $TEST_URL/post do |res|
  assert_eq $res.status 201

http.get $TEST_URL/not-found status: :IGNORE: do |res|
  assert_eq $res.status 404

http.get $TEST_URL/headers do |res|
  assert_eq $res.status 200
  let headers = res.headers
  let custom = headers["x-custom"]
  assert_eq $custom "test-value"

if HAVE_JSON
  http.get $TEST_URL/api/users do |res|
    assert_eq $res.status 200
    let data = res.json()
    let user0 = data[0]
    let user1 = data[1]
    assert_eq $user0["name"] "alice"
    assert_eq $user1["name"] "bob"
