import json:
  - to_str
  - from_str

def assert_err_contains needle block
  let res = try
    block()
    false
  catch e
    assert $ (str e).contains $needle
    true
  assert $res

# Primitives
assert_eq (from_str "null") nil
assert_eq (from_str "true") true
assert_eq (from_str "false") false
assert_eq (from_str "42") 42
assert_eq (from_str "3.14") 3.14
assert_eq (from_str "\"hello\"") "hello"

# Round-trip primitives
assert_eq (from_str $ to_str nil) nil
assert_eq (from_str $ to_str true) true
assert_eq (from_str $ to_str false) false
assert_eq (from_str $ to_str 42) 42
assert_eq (from_str $ to_str 3.14) 3.14
assert_eq (from_str $ to_str "hello") "hello"

# Arrays
assert_eq (from_str "[]") []
assert_eq (from_str "[1, 2, 3]") [1, 2, 3]
assert_eq (from_str "[\"a\", \"b\"]") ["a", "b"]
assert_eq (from_str "[true, false, null]") [true, false, nil]

# Nested arrays
assert_eq (from_str "[[1, 2], [3, 4]]") [[1, 2], [3, 4]]
assert_eq (from_str "[1, [2, 3], 4]") [1, [2, 3], 4]

# Round-trip arrays
assert_eq (from_str $ to_str []) []
assert_eq (from_str $ to_str [1, 2, 3]) [1, 2, 3]
assert_eq (from_str $ to_str ["a", "b"]) ["a", "b"]

# Objects/Maps
assert_eq (from_str "{}") {}
let obj = from_str "{\"a\": 1, \"b\": 2}"
assert_eq $obj["a"] 1
assert_eq $obj["b"] 2

# Nested objects
let nested = from_str "{\"x\": {\"y\": {\"z\": 42}}}"
assert_eq $nested["x"]["y"]["z"] 42

# Mixed objects and arrays
let mixed = from_str "{\"items\": [1, 2, 3], \"count\": 3}"
assert_eq (type mixed["items"]) $array
assert_eq $mixed["count"] 3

# Round-trip objects
let orig = {"foo":  42, "bar": "hello", "baz": true}
let serialized = to_str $orig
let deserialized = from_str $serialized
assert_eq $deserialized["foo"] 42
assert_eq $deserialized["bar"] "hello"
assert_eq $deserialized["baz"] true

# Complex nested structure
let complex =
  users: 
    - name: alice
      age: 30
    - name: bob
      age: 25
  total: 2
let json_str = to_str $complex
let parsed = from_str $json_str
assert_eq $parsed["total"] 2
let users = parsed["users"]
assert_eq (type users) $array

# Symbols serialize as strings
let map_with_sym = {"key":  :test:}
let json_str = to_str $map_with_sym
let parsed = from_str $json_str
assert_eq $parsed["key"] "test"

# Empty collections
assert_eq (from_str $ to_str []) []
assert_eq (from_str $ to_str {}) {}

# Large integers
assert_eq (from_str "9223372036854775807") 9223372036854775807
assert_eq (from_str "-9223372036854775808") -9223372036854775808
assert_err_contains "outside i64 range" do to_str 170141183460469231731687303715884105727

# Floating point preservation
assert_eq (from_str "1.5") 1.5
assert_eq (from_str "-2.25") -2.25
assert_eq (from_str "0.0") 0.0

# Multiple keys in map
let multi_map = from_str "{\"a\": 1, \"b\": 2, \"c\": 3, \"d\": 4}"
assert_eq $multi_map["a"] 1
assert_eq $multi_map["b"] 2
assert_eq $multi_map["c"] 3
assert_eq $multi_map["d"] 4

# Whitespace handling
assert_eq (from_str "  { \"a\" : 1 }  ") {"a": 1}
assert_eq (from_str "[\n  1,\n  2,\n  3\n]") [1, 2, 3]

# Escape sequences in strings
assert_eq (from_str "\"hello\\nworld\"") "hello\nworld"
assert_eq (from_str "\"quote: \\\"test\\\"\"") "quote: \"test\""
