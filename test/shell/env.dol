import agent sys
  test:
    - assert
    - assert_eq
    - assert_throws
  std:
    - MissingPosError
    - TypeError

let host_cpu = sys.cpu_info()
let host_os = sys.os_info()

#[agent.test]
def env_scopes_and_restores_values()
  let cpu = sys.cpu_info()
  let os = sys.os_info()

  assert (cpu.logical_count >= 1)
  assert (cpu.arch)
  assert (os.os)
  assert (os.family)
  assert_eq $cpu.arch $host_cpu.arch
  assert_eq $cpu.logical_count $host_cpu.logical_count
  assert_eq $os.os $host_os.os
  assert_eq $os.family $host_os.family

  if (os.os == :WINDOWS:)
    assert_eq $os.is_wine $host_os.is_wine

  let baseline = {...env}
  assert (baseline.contains "PATH")

  env TEST_DOLANG_ENV_BASE: baseline TEST_DOLANG_ENV_OTHER: keep do
    env PATH: overlay TEST_DOLANG_ENV_ADDED: added TEST_DOLANG_ENV_BASE: nil do
      let snapshot = {...env}

      assert_eq $snapshot["PATH"] overlay
      assert_eq $snapshot["TEST_DOLANG_ENV_ADDED"] added
      assert_eq $snapshot["TEST_DOLANG_ENV_OTHER"] keep
      assert (!snapshot.contains "TEST_DOLANG_ENV_BASE")

      bind env
        first = "missing"
        ...
      assert_eq $first missing

      assert_throws $MissingPosError do
        let _ ... = env

      let :PATH :TEST_DOLANG_ENV_ADDED ...rest = env
      assert_eq $PATH overlay
      assert_eq $TEST_DOLANG_ENV_ADDED added

      let :TEST_DOLANG_ENV_OTHER ...remaining = rest
      let remaining_map = {...remaining}
      assert_eq $TEST_DOLANG_ENV_OTHER keep
      assert (!remaining_map.contains "PATH")
      assert (!remaining_map.contains "TEST_DOLANG_ENV_ADDED")
      assert (!remaining_map.contains "TEST_DOLANG_ENV_BASE")

#[agent.test]
def env_accepts_override_dict()
  env TEST_DOLANG_ENV_INHERITED: inherited TEST_DOLANG_ENV_UNSET: present do
    let overrides =
      "TEST_DOLANG_ENV_STRING": 42
      TEST_DOLANG_ENV_SYMBOL: symbol
      TEST_DOLANG_ENV_UNSET: nil
      TEST_DOLANG_ENV_INHERITED: :INHERIT:
      TEST_DOLANG_ENV_MISSING: :INHERIT:
    env $overrides do
      assert_eq $env["TEST_DOLANG_ENV_STRING"] "42"
      assert_eq $env["TEST_DOLANG_ENV_SYMBOL"] symbol
      assert_eq $env["TEST_DOLANG_ENV_INHERITED"] inherited
      assert_eq $env.get("TEST_DOLANG_ENV_UNSET") nil
      assert_eq $env.get("TEST_DOLANG_ENV_MISSING") nil

    assert_eq $env.get("TEST_DOLANG_ENV_STRING") nil
    assert_eq $env.get("TEST_DOLANG_ENV_SYMBOL") nil
    assert_eq $env["TEST_DOLANG_ENV_UNSET"] present

  assert_throws $TypeError do env ["bad"] do nil
  assert_throws $TypeError do env {1: "bad"} do nil
