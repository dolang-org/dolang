import sys agent _vfs
  strand:
    - stream
  test:
    - assert_eq
    - assert_throws
    - skip
    - test
  shell:
    - Vfs
    - with_host
    - vfs_exe
  fs:
    - Path
    - open
    - with_temp_dir
  std:
    - RuntimeError

let launch_cwd = cd()
let vfs_bin = _vfs.bin()

#[agent.test]
def resets_context_to_defaults()
  # Change directory, re-enter host context
  with_temp_dir do |dir| cd $dir do with_host do
    # Should be back to original directory
    assert_eq $cd() $launch_cwd

#[test]
def windows_admin_captures_current_cwd()
  if (sys.os_info().family != :WINDOWS:)
    skip "requires Windows"

  with_temp_dir do |dir|
    env TEST_DOLANG_WINDOWS_INHERIT: inherited TEST_DOLANG_WINDOWS_UNSET: present do
      let vfs = Vfs.windows_admin
        elevate: false
        cd: $dir
        env:
          "TEST_DOLANG_WINDOWS_STRING": 42
          TEST_DOLANG_WINDOWS_UNSET: nil
          TEST_DOLANG_WINDOWS_INHERIT: :INHERIT:
      try
        vfs.with do
          assert_eq $cd() $dir
          assert_eq $env["TEST_DOLANG_WINDOWS_STRING"] "42"
          assert_eq $env["TEST_DOLANG_WINDOWS_INHERIT"] inherited
          assert_eq $env.get("TEST_DOLANG_WINDOWS_UNSET", default: nil) nil
      finally
        vfs.stop()

#[test]
def stdio_vfs_runs_over_strand_stream()
  with_temp_dir do |dir| cd $dir do
    let marker = (dir / "marker")
    let expected_exe = (Path vfs_bin).canonical()
    assert_eq $vfs_exe() nil
    let vfs = Vfs do run $vfs_bin --stdio
    try
      vfs.with do
        assert_eq $vfs_exe() $expected_exe
        assert_eq $_vfs.bin() $expected_exe
        let background = stream do vfs_exe()
        assert_eq $background.join() $expected_exe
        with_host do assert_eq $vfs_exe() nil
        open $marker w do |file| file.write "remote"
    finally
      vfs.stop()

    open $marker r do |file| assert_eq $file.read() "remote"

#[test]
def stdio_vfs_reports_launcher_error()
  let err = assert_throws $RuntimeError do
    Vfs do throw RuntimeError "launcher failed"
  assert_eq $str(err) "launcher failed"
