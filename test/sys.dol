import sys
  test:
    - assert
    - assert_type
    - assert_throws
    - test
  std:
    - FieldError
  sys:
    - CpuInfo
    - OsInfo

#[test]
def sys_reports_basic_information()
  let os = sys.os_info()
  let cpu = sys.cpu_info()

  assert_type $OsInfo $os
  assert $os.os
  assert $os.family

  if (os.family == :windows:)
    assert_type $bool $os.is_wine
  else
    assert_throws $FieldError do os.is_wine

  assert_type $CpuInfo $cpu
  assert $cpu.arch
  assert (cpu.logical_count >= 1)
