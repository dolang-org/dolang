import sys
  sys.windows:
    - Guid
  sys:
    - NotFoundError
  std:
    - FieldError
    - ImmutableError
    - UnsupportedError
    - ValueError
    - bin
    - bool
    - hash
    - int
    - str
    - tuple
  test:
    - assert_eq
    - assert_throws
    - assert_type
    - test
  security:
    - token_info
    - unix_info
    - user_name
    - user_id
    - group_name
    - group_id
  security.unix:
    - Identity
  security.windows:
    - Ace
    - Acl
    - SecDesc
    - Sid
    - SidName
    - TokenGroup
    - TokenInfo

#[test]
def sid_converts_between_structural_forms()
  let sid = Sid S-1-5-32-544
  assert_type $Sid $sid
  assert_eq $sid.revision 1
  assert_eq $sid.identifier_authority 5
  assert_eq $sid.sub_authority_count 2
  assert_type $tuple $sid.sub_authorities
  assert_eq $sid.sub_authorities[0] 32
  assert_eq $sid.sub_authorities[1] 544
  assert_eq (str sid) S-1-5-32-544
  let bytes = sid.to_bin()
  assert_type $bin $bytes
  assert_eq (str(Sid(bytes))) S-1-5-32-544

#[test]
def security_descriptor_converts_self_relative_packets()
  let packet = b"\x01\x5a\x15\xd0\x14\x00\x00\x00\x20\x00\x00\x00\x00\x00\x00\x00\x30\x00\x00\x00\x01\x01\x00\x00\x00\x00\x00\x05\x12\x00\x00\x00\x01\x02\x00\x00\x00\x00\x00\x05\x20\x00\x00\x00\x20\x02\x00\x00\x02\x00\x08\x00\x00\x00\x00\x00"
  let descriptor = SecDesc $packet
  assert_type $SecDesc $descriptor
  assert_eq $descriptor.revision 1
  assert_eq $descriptor.mask 15
  assert_eq $descriptor.control 20501
  assert_eq $descriptor.rm_control_valid true
  assert_eq $descriptor.rm_control 90
  assert_eq (str descriptor.owner) S-1-5-18
  assert_eq (str descriptor.group) S-1-5-32-544
  assert_eq $descriptor.owner_defaulted true
  assert_eq $descriptor.group_defaulted false
  assert_eq $descriptor.dacl_present true
  assert_eq $descriptor.dacl_defaulted false
  assert_eq $descriptor.dacl_auto_inherit_required false
  assert_eq $descriptor.dacl_auto_inherited false
  assert_eq $descriptor.dacl_protected true
  assert_eq $descriptor.sacl_present true
  assert_eq $descriptor.sacl_defaulted false
  assert_eq $descriptor.sacl_auto_inherit_required false
  assert_eq $descriptor.sacl_auto_inherited false
  assert_eq $descriptor.sacl_protected false
  assert_eq $descriptor.to_bin() $packet

  let empty = SecDesc b"\x01\x00\x00\x80\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00"
  assert_throws $FieldError do empty.owner
  assert_throws $FieldError do empty.group
  assert_throws $FieldError do empty.rm_control

#[test]
def guid_converts_between_windows_structural_forms()
  let guid = Guid 00112233-4455-6677-8899-aabbccddeeff
  assert_type $Guid $guid
  assert_eq (str guid) 00112233-4455-6677-8899-aabbccddeeff
  assert_eq $guid (Guid "00112233-4455-6677-8899-AABBCCDDEEFF")
  assert_eq (hash guid) (hash(Guid(guid.to_bin())))
  assert_eq $guid.to_bin() b"\x33\x22\x11\x00\x55\x44\x77\x66\x88\x99\xaa\xbb\xcc\xdd\xee\xff"

#[test]
def security_descriptor_exposes_acl_and_ace_views()
  let packet = b"\x01\x00\x04\x80\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x14\x00\x00\x00\x02\x00\x58\x00\x03\x00\x00\x00\x00\x13\x1c\x00\x78\x56\x34\x12\x01\x02\x00\x00\x00\x00\x00\x05\x20\x00\x00\x00\x20\x02\x00\x00\xde\xad\xbe\xef\x0b\x00\x2c\x00\xef\xcd\xab\x90\x01\x00\x00\x00\x33\x22\x11\x00\x55\x44\x77\x66\x88\x99\xaa\xbb\xcc\xdd\xee\xff\x01\x01\x00\x00\x00\x00\x00\x01\x00\x00\x00\x00\x01\x02\x03\x04\x7f\xa0\x08\x00\x11\x22\x33\x44"
  let descriptor = SecDesc $packet
  let acl = descriptor.dacl
  assert_type $Acl $acl
  assert_eq $acl.revision 2
  assert_eq $acl.size 88
  assert_eq $acl.ace_count 3
  assert_eq $acl.to_bin() $packet[20..]
  assert_eq $acl.aces.len 3
  assert_throws $ImmutableError do
    acl.aces[0] = nil

  let allowed = acl.aces[0]
  assert_type $Ace $allowed
  assert_eq $allowed.type :ACCESS_ALLOWED:
  assert_eq $allowed.type_code 0
  assert_eq $allowed.flags 19
  assert_eq $allowed.size 28
  assert_eq $allowed.mask 305419896
  assert_eq (str allowed.sid) S-1-5-32-544
  assert_eq $allowed.object_inherit true
  assert_eq $allowed.container_inherit true
  assert_eq $allowed.inherited true
  assert_eq $allowed.application_data b"\xde\xad\xbe\xef"
  assert_throws $FieldError do allowed.object_type
  assert_throws $FieldError do allowed.successful_access

  let object = acl.aces[1]
  assert_eq $object.type :ACCESS_ALLOWED_CALLBACK_OBJECT:
  assert_eq $object.mask 2427178479
  assert_eq $object.object_flags 1
  assert_type $Guid $object.object_type
  assert_eq (str object.object_type) 00112233-4455-6677-8899-aabbccddeeff
  assert_eq $object.inherited_object_type nil
  assert_eq (str object.sid) S-1-1-0
  assert_eq $object.application_data b"\x01\x02\x03\x04"

  let unknown = acl.aces[2]
  assert_eq $unknown.type :UNKNOWN:
  assert_eq $unknown.type_code 127
  assert_eq $unknown.flags 160
  assert_eq $unknown.to_bin() b"\x7f\xa0\x08\x00\x11\x22\x33\x44"
  assert_throws $FieldError do unknown.mask
  assert_throws $FieldError do unknown.application_data

  assert_throws $FieldError do descriptor.sacl
  let null_dacl = SecDesc b"\x01\x00\x04\x80\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00"
  assert_eq $null_dacl.dacl nil
  let absent = SecDesc b"\x01\x00\x00\x80\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00"
  assert_throws $FieldError do absent.dacl

#[test]
def constructs_aces_and_acls()
  let sid = Sid S-1-1-0
  let guid = Guid 00112233-4455-6677-8899-aabbccddeeff
  let allowed = Ace.allow(sid, 305419896, flags: 3, application_data: b"\x01\x02\x03")
  assert_type $Ace $allowed
  assert_eq $allowed.type :ACCESS_ALLOWED:
  assert_eq $allowed.flags 3
  assert_eq $allowed.mask 305419896
  assert_eq $allowed.application_data b"\x01\x02\x03\x00"

  let denied = Ace.deny(sid, 1, object_type: guid, callback: true)
  assert_eq $denied.type :ACCESS_DENIED_CALLBACK_OBJECT:
  assert_eq $denied.object_flags 1
  assert_eq $denied.object_type $guid

  let audited = Ace.audit(sid, 2, successful: true, failed: false)
  assert_eq $audited.type :SYSTEM_AUDIT:
  assert_eq $audited.successful_access true
  assert_eq $audited.failed_access false
  assert_throws $ValueError do
    Ace.audit $sid 2 successful: false failed: false
  assert_throws $ValueError do
    Ace.audit $sid 2 successful: true failed: false flags: 64

  let acl = Acl [allowed, denied, audited]
  assert_type $Acl $acl
  assert_eq $acl.revision 4
  assert_eq $acl.ace_count 3
  assert_eq $acl.aces[0].to_bin() $allowed.to_bin()
  assert_eq $acl.aces[1].to_bin() $denied.to_bin()
  assert_eq $acl.aces[2].to_bin() $audited.to_bin()
  assert_throws $ValueError do Acl [denied] revision: 2

#[test]
def functionally_updates_security_descriptors()
  let empty = SecDesc b"\x01\x00\x00\x80\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00"
  let sid = Sid S-1-5-18
  let acl = Acl []
  let updated = empty.with
    owner: $sid
    dacl: $acl
    owner_defaulted: true
    dacl_protected: true
    rm_control: 90
  let constructed = SecDesc
    owner: $sid
    dacl: $acl
    owner_defaulted: true
    dacl_protected: true
    rm_control: 90
  assert_eq $constructed.to_bin() $updated.to_bin()
  assert_eq (str updated.owner) S-1-5-18
  assert_eq $updated.owner_defaulted true
  assert_eq $updated.dacl_present true
  assert_eq $updated.dacl_protected true
  assert_eq $updated.dacl.to_bin() $acl.to_bin()
  assert_eq $updated.rm_control 90
  assert_throws $FieldError do empty.owner

  let null = updated.with(dacl: nil, rm_control: nil)
  assert_eq $null.dacl nil
  assert_eq $null.rm_control_valid false
  let absent = null.with(dacl_present: false)
  assert_eq $absent.dacl_present false
  assert_throws $FieldError do absent.dacl
  assert_throws $ValueError do empty.with(dacl_present: true)
  assert_throws $ValueError do updated.with(dacl: acl, dacl_present: false)
  let loaded_absent = SecDesc(dacl_present: false)
  assert_eq $loaded_absent.dacl_present false
  assert_throws $ValueError do SecDesc(empty.to_bin(), dacl: acl)

#[test]
def reports_security_information_for_target()
  if (sys.os_info().family == :UNIX:)
    let info = unix_info()
    assert_type $Identity $info
    assert_type $int $info.uid
    assert_type $int $info.gid
    assert_type $int $info.euid
    assert_type $int $info.egid
    assert_type $tuple $info.group_ids
    for group_id = info.group_ids
      assert_type $int $group_id
    let user = user_name $info.euid
    let group = group_name $info.egid
    assert_type $str $user
    assert_type $str $group
    assert_eq (user_id user) $info.euid
    assert_eq (user_id(user_name())) $info.uid
    assert_eq (group_id group) $info.egid
    assert_throws $NotFoundError do user_id dolang-user-that-does-not-exist
    assert_throws $NotFoundError do group_id dolang-group-that-does-not-exist
    assert_throws $UnsupportedError do token_info()
    assert_throws $UnsupportedError do (Sid "S-1-5-32-544").lookup()
  else
    let info = token_info()
    assert_type $TokenInfo $info
    assert_type $bool $info.is_elevated
    assert_type $Sid $info.user_sid
    assert_type $Sid $info.owner_sid
    assert_type $Sid $info.primary_group_sid
    let sid_name = info.user_sid.lookup()
    assert_type $SidName $sid_name
    assert_type $Sid $sid_name.sid
    assert_type $str $sid_name.name
    assert_type $str $sid_name.domain
    assert_type $str $sid_name.qualified_name
    assert_eq (user_name()) $sid_name.name
    let by_sid = SidName.lookup $info.user_sid
    let by_name = SidName.lookup $sid_name.qualified_name
    assert_eq (str by_sid.sid) (str info.user_sid)
    assert_eq (str by_name.sid) (str info.user_sid)
    assert_eq $sid_name.kind :USER:
    assert_throws $NotFoundError do SidName.lookup dolang-account-that-does-not-exist
    assert_throws $UnsupportedError do user_name 0
    let groups = info.groups
    assert_type $int $groups.len
    assert_type $TokenGroup $groups[0]
    let snapshot = [...groups]
    assert_eq $snapshot.len $groups.len
    let first ...rest = groups
    assert_type $TokenGroup $first
    assert_eq (snapshot[1..].len) (array(rest).len)
    assert_throws $ImmutableError do
      groups[0] = nil
    for group = groups
      assert_type $TokenGroup $group
      assert_type $Sid $group.sid
      assert_type $int $group.attributes
      assert_type $bool $group.mandatory
      assert_type $bool $group.enabled_by_default
      assert_type $bool $group.enabled
      assert_type $bool $group.owner
      assert_type $bool $group.use_for_deny_only
      assert_type $bool $group.integrity
      assert_type $bool $group.integrity_enabled
      assert_type $bool $group.resource
      assert_type $bool $group.logon_id
      if group.logon_id
        assert_eq (str group.sid) (str info.logon_sid)
    assert_throws $UnsupportedError do unix_info()
