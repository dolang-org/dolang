import
  compile
  strand
  term
  test:
    - assert
    - assert_eq
    - test

#[test]
def compile_diagnostic()
  let result = compile.compile "bad.dol" "let =\n"
  let diag = result.diagnostics[0]

  let rendered = diag.render()
  assert_eq (type rendered) $term.Text
  assert ((str rendered).contains "expected at least one item")
  assert ((str rendered).contains "bad.dol")
  assert (!(str(rendered).ends_with("\n")))

#[test]
def error()
  let plain = try
    throw "boom"
  catch e
    term.render_error $e
  assert_eq (type plain) $term.Text
  assert ((str plain).contains "boom")
  assert (!(str(plain).ends_with("\n")))

#[test]
def error_explicit_backtrace()
  let color = try
    throw "boom"
  catch e
    term.render_error $e backtrace: (strand.error_backtrace())
  assert ((str color).contains "boom")

#[test]
def error_no_backtrace()
  let err = try
    term.render_error "boom"
  catch e
    e
  assert_eq (str err) "state error: no active handled exception"

#[test]
def error_bad_type()
  let type_err = try
    term.render_error "boom" backtrace: "bad"
  catch e
    e
  assert_eq (str type_err) "type error: expected strand.Backtrace"
