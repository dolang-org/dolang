import sys agent
  test:
    - assert
    - assert_eq
    - assert_type
    - assert_throws
    - skip
  std:
    - RuntimeError
  fs:
    - FsMetadata
    - Metadata
    - Path
    - fs_metadata
    - metadata
    - open
    - remove
    - set_metadata
  security.windows:
    - Sid
  time:
    - DateTime

#[agent.test]
def basic()
  let test_path = "test_metadata.txt"

  # Create test file with some content
  open $test_path w do |f|
    f.write "hello world"

  # Get metadata
  open $test_path r do |f|
    let meta = f.metadata()
    assert_type $Metadata $meta
    assert_eq $meta.len 11
    assert_eq $meta.type :FILE:
    assert_type $DateTime $meta.modified
    assert (meta.modified.unix_secs > 0.0)

  # Cleanup
  remove $test_path

#[agent.test]
def timestamps()
  let test_path = "test_metadata_time.txt"

  # Create test file
  open $test_path w do |f|
    f.write "timestamp test"

  # Get metadata
  open $test_path r do |f|
    let meta = f.metadata()
    assert_type $Metadata $meta
    let modified = meta.modified
    assert_type $DateTime $modified
    assert (modified.unix_secs > 0.0)  # positive timestamp

  # Cleanup
  remove $test_path

#[agent.test]
def closed_fails()
  let test_path = "test_metadata_closed.txt"

  open $test_path w do |f|
    f.write "test content"
    f.close()
    assert_throws $RuntimeError do
      f.metadata()

  remove $test_path

#[agent.test]
def unix_fields()
  if (sys.os_info().family == :WINDOWS:)
    skip "requires non-Windows"
  let test_path = "test_metadata_unix.txt"

  open $test_path w do |f|
    f.write "unix metadata test"

  open $test_path r do |f|
    let meta = f.metadata()
    assert_type $Metadata $meta
    assert (meta.mode > 0)
    assert (meta.dev >= 0)
    assert (meta.ino >= 0)
    assert (meta.nlink >= 1)
    assert (meta.uid >= 0)
    assert (meta.gid >= 0)
    assert (meta.rdev >= 0)
    assert (meta.blksize >= 0)
    assert (meta.blocks >= 0)

  remove $test_path

#[agent.test]
def windows_attrs()
  if (sys.os_info().family != :WINDOWS:)
    skip "requires Windows"
  let test_path = "test_metadata_windows.txt"

  open $test_path w do |f|
    f.write "windows metadata test"

  open $test_path r do |f|
    let meta = f.metadata()
    assert_type $Metadata $meta
    assert_type $Sid $meta.user
    assert_type $Sid $meta.group
    assert_type $int $meta.win_attrs
    assert_type $bool $meta.readonly
    assert_type $bool $meta.hidden
    assert_type $bool $meta.system
    assert_type $bool $meta.archive
    assert_type $bool $meta.reparse_point
    assert_type $bool $meta.compressed
    assert_type $bool $meta.encrypted
    assert_type $bool $meta.temporary
    assert_type $bool $meta.offline
    assert_type $bool $meta.not_content_indexed

    let path_meta = Path(test_path).metadata()
    assert_eq $meta.win_attrs $path_meta.win_attrs

    set_metadata $test_path readonly: true
    let readonly_meta = metadata $test_path
    assert_eq $readonly_meta.readonly true
    Path(test_path).set_metadata readonly: false
    let writable_meta = Path(test_path).metadata()
    assert_eq $writable_meta.readonly false

  if !sys.os_info().is_wine
    set_metadata $test_path compressed: true
    let compressed_meta = metadata $test_path
    assert_eq $compressed_meta.compressed true
    Path(test_path).set_metadata compressed: false
    let uncompressed_meta = Path(test_path).metadata()
    assert_eq $uncompressed_meta.compressed false

  remove $test_path

#[agent.test]
def windows_batch_attrs()
  if (sys.os_info().family != :WINDOWS:)
    skip "requires Windows"
  let first = "test_metadata_windows_batch_1.txt"
  let second = "test_metadata_windows_batch_2.txt"
  open $first w do |f|
    f.write "one"
  open $second w do |f|
    f.write "two"

  set_metadata $first $second readonly: true
  assert_eq (metadata(first).readonly) true
  assert_eq (metadata(second).readonly) true
  set_metadata $first $second readonly: false

  remove $first
  remove $second

#[agent.test]
def linux_attrs()
  if (sys.os_info().os != :LINUX:)
    skip "requires Linux"
  let test_path = "test_metadata_linux_attrs.txt"
  open $test_path w do |f|
    f.write "linux attrs test"

  let meta = metadata $test_path
  assert_type $Metadata $meta
  assert_type $int $meta.linux_attrs
  assert_type $bool $meta.immutable
  assert_type $bool $meta.append_only
  assert_type $bool $meta.no_dump
  assert_type $bool $meta.no_atime
  assert_type $bool $meta.no_copy_on_write
  assert_type $bool $meta.dir_sync
  assert_type $bool $meta.casefold
  assert_type $bool $meta.data_journaling
  assert_type $bool $meta.no_compress
  assert_type $bool $meta.project_inherit
  assert_type $bool $meta.secure_delete
  assert_type $bool $meta.sync
  assert_type $bool $meta.no_tail_merge
  assert_type $bool $meta.top_dir
  assert_type $bool $meta.undelete
  assert_type $bool $meta.direct_access
  assert_type $bool $meta.extent_format

  set_metadata $test_path no_dump: true
  let no_dump_meta = metadata $test_path
  assert_eq $no_dump_meta.no_dump true
  Path(test_path).set_metadata no_dump: false
  let normal_meta = Path(test_path).metadata()
  assert_eq $normal_meta.no_dump false

  remove $test_path

#[agent.test]
def macos_attrs()
  if (sys.os_info().os != :MACOS:)
    skip "requires macOS"
  let test_path = "test_metadata_macos_attrs.txt"
  open $test_path w do |f|
    f.write "macos attrs test"

  let meta = metadata $test_path
  assert_type $Metadata $meta
  assert_type $int $meta.macos_attrs
  assert_type $bool $meta.hidden
  assert_type $bool $meta.compressed
  assert_type $bool $meta.immutable
  assert_type $bool $meta.append_only
  assert_type $bool $meta.no_dump
  assert_type $bool $meta.opaque

  set_metadata $test_path hidden: true no_dump: true
  let hidden_meta = metadata $test_path
  assert_eq $hidden_meta.hidden true
  assert_eq $hidden_meta.no_dump true
  Path(test_path).set_metadata hidden: false no_dump: false
  let normal_meta = Path(test_path).metadata()
  assert_eq $normal_meta.hidden false
  assert_eq $normal_meta.no_dump false

  remove $test_path

#[agent.test]
def len_type()
  # Test metadata returns correct len and type for a file
  let test_path = "test_metadata_len.txt"

  open $test_path w do |f|
    f.write "test"

  open $test_path r do |f|
    let meta = f.metadata()
    assert_type $Metadata $meta
    assert_eq $meta.len 4
    assert_eq $meta.type :FILE:

  remove $test_path

#[agent.test]
def fs_basic()
  let test_path = "test_fs_metadata.txt"

  open $test_path w do |f|
    f.write "test"

  let direct = fs_metadata $test_path
  assert_type $FsMetadata $direct
  assert (direct.capacity > 0)
  assert (direct.free > 0)
  assert (direct.available > 0)
  assert_eq $direct.read_only false

  let path_meta = Path(test_path).fs_metadata()
  assert_type $FsMetadata $path_meta
  assert_eq $path_meta.capacity $direct.capacity

  open $test_path r do |f|
    let file_meta = f.fs_metadata()
    assert_type $FsMetadata $file_meta
    assert_eq $file_meta.capacity $direct.capacity

  remove $test_path

#[agent.test]
def unix_raw()
  if (sys.os_info().family == :WINDOWS:)
    skip "requires non-Windows"
  let test_path = "test_fs_metadata_unix.txt"
  open $test_path w do |f|
    f.write "test"

  let meta = fs_metadata $test_path
  assert_type $int $meta.blocks
  assert_type $int $meta.blocks_free
  assert_type $int $meta.blocks_available
  assert_type $int $meta.files
  assert_type $int $meta.files_free
  assert_type $int $meta.files_available
  if (sys.os_info().os == :LINUX:)
    assert_type $int $meta.linux_attrs
  else
    assert_type $int $meta.macos_attrs
  assert_type $int $meta.name_max

  remove $test_path
