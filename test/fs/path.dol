import sys
  test:
    - assert
    - assert_eq
    - assert_ne
    - assert_throws
    - assert_type
    - test
  std:
    - arg
    - FieldError
    - hash
    - TypeError
    - ValueError
  fs:
    - exists
    - normalize
    - Path
    - UnixPath
    - WindowsPath

#[test]
def path_api()
  # Test path object creation
  let p = Path "foo/bar.txt"

  if (sys.os_info().family == :WINDOWS:)
    assert_eq (dbg p) "<WindowsPath \"foo/bar.txt\">"
  else
    assert_eq (dbg p) "<UnixPath \"foo/bar.txt\">"
  assert_eq (str p) "foo/bar.txt"
  assert_eq (arg p) "foo/bar.txt"

  # Test path name field
  let path1 = Path "foo/bar/baz.txt"
  assert_eq $path1.name "baz.txt"

  let root_file = Path "file.txt"
  assert_eq $root_file.name "file.txt"

  # Test path extension field
  let ext1 = Path "file.txt"
  assert_eq $ext1.ext "txt"

  let ext2 = Path "archive.tar.gz"
  assert_eq $ext2.ext "gz"

  let no_ext = Path "Makefile"
  assert_eq $no_ext.ext nil

  # Test path stem field
  let stem1 = Path "file.txt"
  assert_eq $stem1.stem "file"

  let stem2 = Path "archive.tar.gz"
  assert_eq $stem2.stem "archive.tar"

  let stem3 = Path "Makefile"
  assert_eq $stem3.stem "Makefile"

  # Test components view
  let components = (Path "alpha/beta/gamma").components
  assert_eq [...components] ["alpha", "beta", "gamma"]

  let unpacked = (Path "alpha/beta/gamma").components
  let first ...rest = unpacked
  assert_eq $first "alpha"
  assert_eq [...rest] ["beta", "gamma"]
  assert_eq $unpacked[0] "alpha"
  let sliced = components[1..]
  assert_eq $sliced ["beta", "gamma"]
  assert_eq $components[..-1] ["alpha", "beta"]
  assert_eq $components[range 0 3 2] ["alpha", "gamma"]
  assert_eq $components[range nil nil -1] ["gamma", "beta", "alpha"]
  sliced.push "delta"
  assert_eq $sliced ["beta", "gamma", "delta"]
  assert_eq [...components] ["alpha", "beta", "gamma"]

  # Test extension rewrite methods
  let without_ext1 = Path "file.txt"
  assert_eq $without_ext1.without_ext() (Path "file")

  let without_ext2 = Path "archive.tar.gz"
  assert_eq $without_ext2.without_ext() (Path "archive.tar")

  let without_ext3 = Path "Makefile"
  assert_eq $without_ext3.without_ext() (Path "Makefile")

  let with_ext1 = Path "file.txt"
  assert_eq $with_ext1.with_ext("md") (Path "file.md")

  let with_ext2 = Path "Makefile"
  assert_eq $with_ext2.with_ext("txt") (Path "Makefile.txt")

  let with_name1 = Path "dir/file.txt"
  assert_eq $with_name1.with_name("other.md") (Path "dir/other.md")

  let with_name2 = Path "file.txt"
  assert_eq $with_name2.with_name("report.txt") (Path "report.txt")

  let with_stem1 = Path "dir/file.txt"
  assert_eq $with_stem1.with_stem("report") (Path "dir/report.txt")

  let with_stem2 = Path "archive.tar.gz"
  assert_eq $with_stem2.with_stem("bundle") (Path "bundle.gz")

  let with_stem3 = Path "Makefile"
  assert_eq $with_stem3.with_stem("Dockerfile") (Path "Dockerfile")

  # Test add_ext method
  let add_ext1 = Path "file"
  assert_eq $add_ext1.add_ext("txt") (Path "file.txt")
  assert_eq $add_ext1 (Path "file")

  let add_ext2 = Path "archive.tar"
  assert_eq $add_ext2.add_ext("gz") (Path "archive.tar.gz")

  let add_ext3 = Path "dir/file"
  assert_eq $add_ext3.add_ext("log") (Path "dir/file.log")

  # Test path equality
  let eq1 = Path "foo/bar"
  let eq2 = Path "foo/bar"
  let eq3 = Path "foo/baz"

  assert_eq $eq1 $eq2
  assert_ne $eq1 $eq3

  # Test path comparison and hashing
  let lt1 = Path "foo/bar"
  let lt2 = Path "foo/baz"

  assert (lt1 < lt2)
  assert (lt2 > lt1)
  assert (lt1 <= eq2)
  assert (eq2 >= lt1)
  assert_eq (hash lt1) (hash eq2)
  assert_ne (hash lt1) (hash lt2)

  let d = {}
  d[lt1] = "first"
  assert_eq $d[eq2] "first"

  # Test path join operator
  let joined1 = Path.join "a" "b" "c"
  assert_eq $joined1 (Path "a/b/c")

  let joined2 = Path.join (Path "x") "y"
  assert_eq $joined2 (Path "x/y")

  # Test reverse division (string / Path)
  let base = Path "subdir"
  let full = ("parent" / base)

  assert_eq $full (Path "parent/subdir")

  # Test normalize rename
  let messy = Path "./foo/../bar/./baz"
  assert_eq $messy.normalize() (Path "bar/baz")
  assert_eq $(UnixPath "../foo/..").normalize() (UnixPath "..")
  assert_eq $(UnixPath "foo/../../../bar").normalize() (UnixPath "../../bar")
  assert_eq $(UnixPath "../../foo/../bar").normalize() (UnixPath "../../bar")
  assert_eq (normalize $ UnixPath "../foo/..") (UnixPath "..")
  assert_eq $(WindowsPath r"..\foo\..").normalize() (WindowsPath "..")
  assert_eq $(WindowsPath r"foo\..\..\bar").normalize() (WindowsPath r"..\bar")

  if (sys.os_info().family != :WINDOWS:)
    assert_throws $FieldError do p.disk
    assert_throws $FieldError do p.server
    assert_throws $FieldError do p.share
    assert_throws $FieldError do p.device
    assert_throws $FieldError do p.is_verbatim
    assert_throws $FieldError do p.stream_name
    assert_throws $FieldError do p.stream_type

  # Test type errors on new string-taking methods
  assert_throws $TypeError do with_ext1.with_ext 1
  assert_throws $TypeError do with_name1.with_name 1
  assert_throws $TypeError do with_stem1.with_stem 1

#[test]
def typed_paths()
  let unix = UnixPath r"alpha\beta/gamma"
  let windows = WindowsPath r"alpha\beta/gamma"
  assert_type $UnixPath $unix
  assert_type $Path $unix
  assert_type $WindowsPath $windows
  assert_type $Path $windows
  assert_eq (str unix) r"alpha\beta/gamma"
  assert_eq (str windows) r"alpha\beta/gamma"
  assert_eq (dbg (UnixPath "foo/bar")) "<UnixPath \"foo/bar\">"
  assert_eq (dbg (WindowsPath r"foo\bar")) r#"<WindowsPath "foo\\bar">"#
  assert_ne $unix r"alpha\beta/gamma"
  assert_ne r"alpha\beta/gamma" $unix
  assert_ne (UnixPath "foo/bar") (WindowsPath "foo/bar")

  let smart = Path foo
  if (sys.os_info().family == :WINDOWS:)
    assert_type $WindowsPath $smart
  else
    assert_type $UnixPath $smart

  assert_eq (UnixPath (WindowsPath r"foo\bar")) (UnixPath "foo/bar")
  assert_eq (WindowsPath (UnixPath "foo/bar")) (WindowsPath r"foo\bar")
  assert_eq ((UnixPath "foo") / (WindowsPath r"bar\baz")) (UnixPath "foo/bar/baz")

  let unix_joined = UnixPath.join (UnixPath "alpha") "beta" "gamma"
  let windows_joined = WindowsPath.join (WindowsPath "alpha") "beta" "gamma"
  let smart_unix_joined = Path.join (UnixPath "alpha") "beta"
  let smart_windows_joined = Path.join (WindowsPath "alpha") "beta"
  assert_type $UnixPath $unix_joined
  assert_type $WindowsPath $windows_joined
  assert_type $UnixPath $smart_unix_joined
  assert_type $WindowsPath $smart_windows_joined
  assert_eq (str unix_joined) "alpha/beta/gamma"
  assert_eq (str windows_joined) r"alpha\beta\gamma"
  assert_eq (str smart_unix_joined) "alpha/beta"
  assert_eq (str smart_windows_joined) r"alpha\beta"

  let empty_joined = Path.join()
  assert_eq (str empty_joined) ""
  if (sys.os_info().family == :WINDOWS:)
    assert_type $WindowsPath $empty_joined
  else
    assert_type $UnixPath $empty_joined

  assert_throws $TypeError do UnixPath (WindowsPath r"C:\foo")
  assert_throws $TypeError do UnixPath (WindowsPath r"\\server\share\foo")
  assert_throws $TypeError do UnixPath (WindowsPath "file.txt:stream")
  assert_throws $TypeError do WindowsPath (UnixPath "/foo")
  assert_throws $TypeError do ((UnixPath "foo") / (WindowsPath r"C:\foo"))

  if (sys.os_info().family == :WINDOWS:)
    let foreign = UnixPath "test/fs/path.dol"
    assert_eq (exists foreign) true
    assert_eq $foreign.exists() true
    assert_throws $TypeError do exists (UnixPath "/foo")
    assert_throws $TypeError do (UnixPath "/foo").exists()
    assert_throws $TypeError do (UnixPath "/foo").metadata()
    assert_throws $TypeError do (UnixPath "/foo").open()
  else
    let foreign = WindowsPath r"test\fs\path.dol"
    assert_eq (exists foreign) true
    assert_eq $foreign.exists() true
    assert_throws $TypeError do exists (WindowsPath r"C:\foo")
    assert_throws $TypeError do (WindowsPath r"C:\foo").exists()
    assert_throws $TypeError do (WindowsPath r"C:\foo").metadata()
    assert_throws $TypeError do (WindowsPath r"C:\foo").open()

#[test]
def windows_path_fields()
  let drive = WindowsPath "C:/work/file.txt"
  assert_eq $drive.disk "C"
  assert_eq $drive.server nil
  assert_eq $drive.share nil
  assert_eq $drive.device nil
  assert_eq $drive.is_verbatim false

  let unc = WindowsPath "//server/share/file.txt"
  assert_eq $unc.disk nil
  assert_eq $unc.server "server"
  assert_eq $unc.share "share"
  assert_eq $unc.device nil
  assert_eq $unc.is_verbatim false

  let device = WindowsPath r"\\.\COM42"
  assert_eq $device.disk nil
  assert_eq $device.server nil
  assert_eq $device.share nil
  assert_eq $device.device "COM42"
  assert_eq $device.is_verbatim false

  let verbatim_drive = WindowsPath r"\\?\C:\work\file.txt"
  assert_eq $verbatim_drive.disk "C"
  assert_eq $verbatim_drive.server nil
  assert_eq $verbatim_drive.share nil
  assert_eq $verbatim_drive.device nil
  assert_eq $verbatim_drive.is_verbatim true

  let verbatim_unc = WindowsPath r"\\?\UNC\server\share\file.txt"
  assert_eq $verbatim_unc.disk nil
  assert_eq $verbatim_unc.server "server"
  assert_eq $verbatim_unc.share "share"
  assert_eq $verbatim_unc.device nil
  assert_eq $verbatim_unc.is_verbatim true

  let verbatim = WindowsPath r"\\?\cat_pics"
  assert_eq $verbatim.disk nil
  assert_eq $verbatim.server nil
  assert_eq $verbatim.share nil
  assert_eq $verbatim.device nil
  assert_eq $verbatim.is_verbatim true

#[test]
def windows_path_stream_fields()
  let no_stream = WindowsPath "file.txt"
  assert_eq $no_stream.stream_name nil
  assert_eq $no_stream.stream_type nil

  let named_stream = WindowsPath "file.txt:zone"
  assert_eq (str named_stream) "file.txt:zone"
  assert_eq $named_stream.name "file.txt"
  assert_eq $named_stream.stem "file"
  assert_eq $named_stream.ext "txt"
  assert_eq $named_stream.stream_name "zone"
  assert_eq $named_stream.stream_type nil

  let typed_stream = WindowsPath r"file.txt:zone:$DATA"
  assert_eq (str typed_stream) r"file.txt:zone:$DATA"
  assert_eq $typed_stream.name "file.txt"
  assert_eq $typed_stream.stream_name "zone"
  assert_eq $typed_stream.stream_type "DATA"

  let unnamed_stream = WindowsPath r"file.txt::$DATA"
  assert_eq $unnamed_stream.stream_name ""
  assert_eq $unnamed_stream.stream_type "DATA"

  let stream_components = [...(WindowsPath r"dir/file.txt:zone:$DATA").components]
  assert_eq $stream_components[(stream_components.len - 1)] r"file.txt:zone:$DATA"

  assert_throws $ValueError do WindowsPath "file.txt:zone:DATA"
  assert_throws $ValueError do WindowsPath "file.txt:a:b:c"
