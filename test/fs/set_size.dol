import agent
  test:
    - assert_eq
  fs:
    - open
    - read
    - set_size
    - write
    - Path

#[agent.test]
def file_set_size_preserves_buffered_cursor()
  let path = "test_set_size_file.txt"
  write $path "alpha\nbeta\n"
  open $path r+ do |file|
    assert_eq (file.next()) "alpha"
    assert_eq (file.tell()) 6
    file.set_size 2
    assert_eq (file.tell()) 6
    assert_eq (file.read()) ""

#[agent.test]
def path_set_size_and_fs_set_size_adjust_file_length()
  let path = "test_set_size_path.bin"
  write $path b"abc"

  (Path path).set_size 5
  assert_eq (read path "b") b"abc\0\0"

  set_size $path 2
  assert_eq (read (Path path) "b") b"ab"
