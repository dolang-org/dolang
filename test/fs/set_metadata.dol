import sys
  test:
    - skip
    - assert_eq
    - assert_throws

if (sys.os_info().family == :WINDOWS:)
  skip "requires Unix"

import agent
  fs:
    - Path
    - set_metadata
    - open
    - remove
    - symlink
  proc.run:
    - id
import std:
  - RuntimeError

#[agent.test]
def numeric_id()
  let test_path = "test_chown_ids.txt"

  open $test_path w do |f|
    f.write "ownership"

  let before = Path(test_path).metadata()
  set_metadata $test_path mode: 0o600 user: $before.uid group: $before.gid
  let after = Path(test_path).metadata()
  assert_eq $after.uid $before.uid
  assert_eq $after.gid $before.gid
  assert_eq (after.mode & 0o777) 0o600

  remove $test_path

#[agent.test]
def multiple_paths()
  let first = "test_set_metadata_first.txt"
  let second = "test_set_metadata_second.txt"

  open $first w do |f|
    f.write "first"
  open $second w do |f|
    f.write "second"

  set_metadata $first $second mode: 0o600
  assert_eq (Path(first).metadata().mode & 0o777) 0o600
  assert_eq (Path(second).metadata().mode & 0o777) 0o600

  remove $first $second

#[agent.test]
def user_and_group_name()
  let test_path = "test_chown_names.txt"

  open $test_path w do |f|
    f.write "ownership"

  let before = Path(test_path).metadata()
  let user = sub $id -un
  let group = sub $id -gn
  Path(test_path).set_metadata user: $user group: $group
  let after = Path(test_path).metadata()
  assert_eq $after.uid $before.uid
  assert_eq $after.gid $before.gid

  remove $test_path

#[agent.test]
def group_only()
  let test_path = "test_chown_group.txt"

  open $test_path w do |f|
    f.write "ownership"

  let before = Path(test_path).metadata()
  set_metadata $test_path group: $before.gid
  let after = Path(test_path).metadata()
  assert_eq $after.uid $before.uid
  assert_eq $after.gid $before.gid

  remove $test_path

#[agent.test]
def empty_patch_is_noop()
  let test_path = "test_chown_missing.txt"

  open $test_path w do |f|
    f.write "ownership"

  set_metadata $test_path

  remove $test_path

#[agent.test]
def unknown_user_fails()
  let test_path = "test_chown_unknown.txt"

  open $test_path w do |f|
    f.write "ownership"

  assert_throws $RuntimeError do
    set_metadata $test_path user: "__dolang_missing_user__"

  remove $test_path

#[agent.test]
def follow_controls_symlink_handling()
  let link_path = "test_chown_link"
  let missing_target = "test_chown_missing_target"
  let group = sub $id -gn

  remove $link_path ignore: true

  symlink $missing_target $link_path

  set_metadata $link_path group: $group resolve: :LINK:

  assert_throws $sys.NotFoundError do
    set_metadata $link_path group: $group resolve: :TARGET:

  remove $link_path
