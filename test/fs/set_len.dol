import agent
  test:
    - assert_eq
  fs:
    - open
    - read
    - set_len
    - write
    - Path

#[agent.test remote: false]
def file_set_len_preserves_buffered_cursor()
  let path = "test_set_len_file.txt"
  write $path "alpha\nbeta\n"
  open $path r+ do |file|
    assert_eq (file.next()) "alpha"
    assert_eq (file.tell()) 6
    file.set_len 2
    assert_eq (file.tell()) 6
    assert_eq (file.read()) ""

#[agent.test remote: false]
def path_set_len_and_fs_set_len_adjust_file_length()
  let path = "test_set_len_path.bin"
  write $path b"abc"

  (Path path).set_len 5
  assert_eq (read path "b") b"abc\0\0"

  set_len $path 2
  assert_eq (read (Path path) "b") b"ab"
