import agent sys
  test:
    - assert
    - assert_eq
    - assert_type
    - assert_throws
  fs:
    - open
    - read
    - write
    - remove
    - Path
  std:
    - RuntimeError

let is_windows = (sys.os_info().family == :windows:)

#[agent.test]
def read_entire_file()
  let path = "test_fs_read_source.txt"
  write $path "[package]\nname = \"dolang-ext-shell\"\n"

  # Test reading entire file
  open $path "r" do |file|
    let contents = file.read()
    # Verify we got some string data
    assert (contents.len > 0)
    # Verify it's valid UTF-8 string content
    assert (contents.starts_with("[package]"))
    assert (contents.contains("dolang-ext-shell"))

#[agent.test]
def read_partial()
  let path = "test_fs_read_partial.txt"
  write $path "[package]\nname = \"dolang-ext-shell\"\n"

  # Test reading up to a specific number of bytes
  open $path "r" do |file|
    let first_10 = file.read(10)
    # read() returns up to n bytes, but may return fewer at EOF
    # For text mode, returns complete UTF-8 characters
    assert (first_10.len > 0)
    # Should be valid UTF-8 string
    assert (first_10.starts_with "[package]" )

#[agent.test]
def read_binary_mode()
  let path = "test_fs_read_binary.bin"
  write $path b"[package]\n"

  # Test reading in binary mode
  open $path "rb" do |file|
    let contents = file.read()
    # Verify we got some binary data
    assert $ type $contents $bin
    assert (contents.len > 0)
    # Binary mode returns bytes, check that we got a string representation
    assert (contents.contains "[" )

#[agent.test]
def read_after_close_fails()
  let path = "test_fs_read_closed.txt"
  write $path "content"

  # Test that reading from a closed file fails
  let f = open $path "r"
  f.close()
  assert_throws $RuntimeError do
    f.read()
  remove $path

#[agent.test]
def fs_read_reads_entire_text_file()
  let test_path = "test_fs_read.txt"
  write $test_path "alpha\nbeta\n"
  let contents = read $test_path
  assert_eq $contents "alpha\nbeta\n"
  assert_eq (read (Path test_path)) "alpha\nbeta\n"
  remove $test_path

#[agent.test]
def fs_read_reads_entire_binary_file()
  let test_path = "test_fs_read.bin"
  let data = b"\x00\x01\x02\xff"
  write $test_path $data
  assert_eq (read test_path "b") $data
  assert_eq ((Path test_path).read "b") $data
  remove $test_path

#[agent.test]
def fs_read_grows_for_large_full_reads()
  let test_path = "test_fs_read_large.txt"
  let data = ("abcdefghij".repeat 2000)
  write $test_path $data
  assert_eq (read test_path) $data
  assert_eq ((Path test_path).read()) $data
  remove $test_path

#[agent.test]
def fs_read_rejects_invalid_utf_8_data()
  let test_path = "test_fs_read_invalid.bin"
  write $test_path b"\xff\xfe"
  let err = assert_throws $RuntimeError do
    read $test_path
  assert_eq (str err) "invalid UTF-8 data"
  remove $test_path

#[agent.test]
def fs_read_rejects_invalid_mode()
  let path = "test_fs_read_invalid_mode.txt"
  write $path "hello"
  let err = assert_throws $RuntimeError do
    read $path "rb"
  assert_eq (str err) "type error: fs.read: mode must be `b`"
  remove $path

#[agent.test]
def missing_file_yields_sys_error()
  let missing = Path "missing.txt"
  let err = assert_throws $sys.NotFoundError do
    missing.read()
  assert_type $sys.Error $err
  if !is_windows
    assert_eq $err.errno 2

#[agent.test]
def sys_error_is_caught_by_runtime_error()
  let missing = Path "missing.txt"
  assert_throws $RuntimeError do
    missing.read()
