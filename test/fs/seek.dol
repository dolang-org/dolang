import test:
  - assert_eq
  - assert_throws

import fs:
  - open
  - remove
  - write

import agent
import std:
  - MissingPosError
  - UnexpectedKeyError

#[agent.test remote: false]
def seek_and_tell()
  let path = "test_fs_seek.bin"
  let data = b"abcdef"
  write $path $data
  open $path "rb" do |file|
    assert_eq (file.tell()) 0
    assert_eq (file.seek 2) 2
    assert_eq (file.tell()) 2
    assert_eq (file.seek (0 - 1)) 1
    assert_eq (file.tell()) 1
    assert_eq (file.seek start: 4) 4
    assert_eq (file.tell()) 4
    assert_eq (file.seek end: (0 - 1)) 5
    assert_eq (file.tell()) 5
  remove $path

#[agent.test remote: false]
def seek_clears_buffered_text_reads()
  let path = "test_fs_seek.txt"
  write $path "alpha\nbeta\n"
  open $path "r" do |file|
    assert_eq (file.next()) "alpha"
    assert_eq (file.seek start: 0) 0
    assert_eq (file.next()) "alpha"
  remove $path

#[agent.test remote: false]
def seek_rejects_redundant_args()
  let path = "test_fs_seek_args.txt"
  write $path "abc"
  open $path "r" do |file|
    assert_throws $UnexpectedKeyError do file.seek 1 start: 2
    assert_throws $UnexpectedKeyError do file.seek start: 1 end: 2
    assert_throws $MissingPosError do file.seek()
  remove $path
