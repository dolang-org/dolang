import agent sys
  test:
    - assert_eq
    - assert_throws
  std:
    - RuntimeError
  fs:
    - Path
    - metadata
    - open
    - remove
    - set_metadata
  time:
    - DateTime

#[agent.test]
def set_metadata_updates_timestamps()
  let test_path = "test_utime.txt"
  let first_modified = DateTime.from_unix(1234)
  let first_accessed = DateTime.from_unix(2345)
  let second_modified = DateTime.from_unix(3456)
  let second_accessed = DateTime.from_unix(4567)
  let first_created = DateTime.from_unix(1111)
  let second_created = DateTime.from_unix(2222)

  open $test_path w do |f|
    f.write "set_metadata timestamp test"

  let is_real_windows = (sys.os_info().family == :WINDOWS: && !sys.os_info().is_wine)

  set_metadata $test_path modified: $first_modified accessed: $first_accessed
    if is_real_windows
      created: $first_created
  let meta = metadata(test_path)
  assert_eq $meta.modified.unix_secs 1234.0
  assert_eq $meta.modified.unix_nanos 1234000000000
  assert_eq $meta.accessed.unix_secs 2345.0
  assert_eq $meta.accessed.unix_nanos 2345000000000
  if is_real_windows
    assert_eq $meta.created.unix_secs 1111.0
    assert_eq $meta.created.unix_nanos 1111000000000

  Path(test_path).set_metadata modified: $second_modified accessed: $second_accessed
    if is_real_windows
      created: $second_created
  let meta = Path(test_path).metadata()
  assert_eq $meta.modified.unix_secs 3456.0
  assert_eq $meta.modified.unix_nanos 3456000000000
  assert_eq $meta.accessed.unix_secs 4567.0
  assert_eq $meta.accessed.unix_nanos 4567000000000
  if is_real_windows
    assert_eq $meta.created.unix_secs 2222.0
    assert_eq $meta.created.unix_nanos 2222000000000
  else if !(sys.os_info().family == :WINDOWS:)
    assert_throws $RuntimeError do
      set_metadata $test_path created: $first_created

  remove $test_path

#[agent.test]
def set_metadata_updates_directory_timestamps()
  let path = Path "test_utime_dir"
  let modified = DateTime.from_unix 5678
  path.create_dir()

  path.set_metadata modified: $modified

  let meta = path.metadata()
  assert_eq $meta.modified.unix_secs 5678.0
  assert_eq $meta.modified.unix_nanos 5678000000000
  path.remove_dir()
