import sys sqlite systemd
  fs:
    - with_temp_dir
  test:
    - skip
    - assert
    - assert_eq
    - test

if (sys.os_info().os != :linux:)
  skip "not supported on this system"

let runtime = if run.docker.which()
  import container.docker: docker
  docker
else if run.podman.which()
  import container.podman: podman
  podman
else
  skip "no container runtime available"

#[test]
def read_ubuntu_release()
  bind runtime.with ubuntu:24.04 do systemd.os_release()
    "NAME": name
    "VERSION_ID": ver
    ...
  assert_eq $name Ubuntu
  assert_eq $ver "24.04"

#[test]
def read_fedora_packages()
  let pkgs = runtime.with fedora:43 do
    sqlite.open /var/lib/rpm/rpmdb.sqlite do |conn|
      conn.prepare "SELECT key from Name" do |stmt|
        [...stmt.query().map do |row| row[0]]
  assert $ pkgs.contains bash
  assert $ pkgs.contains sudo

#[test]
def run_direct_command()
  let release = sub do runtime.run ubuntu:24.04 cat /etc/os-release
  assert $ release.contains "NAME=\"Ubuntu\""
  assert $ release.contains "VERSION_ID=\"24.04\""

let container_cli = if run.docker.which()
  run.docker
else
  run.podman

#[test]
def image_build_inspect_remove()
  let image_tag = "dolang-test-image-inspect-remove:latest"
  # Build a minimal image
  let built = runtime.build
    from: ubuntu:24.04
    run: do run touch /test-marker
    tag: $image_tag

  # Inspect via image()
  let img = runtime.image $image_tag
  let tags = img.tags()
  assert_eq $built.id $img.id
  assert_eq $tags[0].repo dolang-test-image-inspect-remove
  assert_eq $tags[0].tag latest
  assert (img.id.starts_with "sha256:")
  assert_eq $img.os linux
  assert (img.layers.len > 0)

  # Verify it shows up in images()
  let found = [...runtime.images filter: "reference=$image_tag"]
  assert_eq $found.len 1
  assert_eq $found[0].id $img.id

  # Clean up
  img.remove()

  # Verify it's gone by catching NoImageError
  let gone = try
    runtime.image $image_tag
    false
  catch runtime.NoImageError: _
    true
  assert $gone

#[test]
def image_build_multi_tag()
  let image_tag = "dolang-test-image-multi-tag:latest"
  let image_tag_alt = "dolang-test-image-multi-tag:alt"
  let img = runtime.build
    from: ubuntu:24.04
    run: do run touch /multi-tag-marker
    tag: $image_tag
    tag: $image_tag_alt

  let latest = runtime.image $image_tag
  let alt = runtime.image $image_tag_alt
  assert_eq $img.id $latest.id
  assert_eq $img.id $alt.id

  latest.remove force: true

#[test]
def image_build_untagged()
  let img = runtime.build
    from: ubuntu:24.04
    run: do run touch /untagged-marker

  assert (img.id.starts_with "sha256:")
  let same = runtime.image $img.id
  assert_eq $same.id $img.id
  assert_eq $img.tags().len 0
  img.remove()

#[test]
def image_save_load()
  let image_archive_tag = "dolang-test-image-save-load:latest"
  runtime.build
    from: ubuntu:24.04
    run: do run touch /archive-marker
    tag: $image_archive_tag

  let img = runtime.image $image_archive_tag

  with_temp_dir do |dir|
    let archive1 = (dir / "method.tar")
    let archive2 = (dir / "free.tar")

    img.save $archive1 format: docker_archive
    runtime.save $archive2 format: :docker_archive: $image_archive_tag

    img.remove()

    let loaded = runtime.load $archive2
    assert_eq $loaded.len 1

    let restored = runtime.image $image_archive_tag
    let tags = restored.tags()
    assert_eq $loaded[0].id $restored.id
    assert_eq $tags[0].repo dolang-test-image-save-load
    assert_eq $tags[0].tag latest

  let restored = runtime.image $image_archive_tag
  restored.remove()

#[test]
def push_missing_image()
  let missing = try
    runtime.push "dolang-definitely-missing-image:latest"
    false
  catch runtime.NoImageError: _
    true
  assert $missing

#[test]
def container_inspect_lifecycle()
  let container_name = "dolang-test-container-inspect-lifecycle"
  let cleanup = do
    try
      let ctr = runtime.container $container_name
      ctr.remove force: true
    catch runtime.NoContainerError: _
      nil

  cleanup()

  try
    sub do container_cli run --init -d --name $container_name ubuntu:24.04 sleep infinity

    let ctr = runtime.container $container_name
    let state = ctr.state()
    assert_eq $state.name $container_name
    assert_eq $ctr.image ubuntu:24.04
    assert_eq $state.state :running:
    assert_eq $state.status running
    assert $ctr.created
    assert_eq $state.ports []

    let listed = [...runtime.containers filter: "name=$container_name"]
    assert_eq $listed.len 1
    assert_eq $listed[0].id $ctr.id

    ctr.stop()
    assert_eq $ctr.state().state :exited:

    let listed_all = [...runtime.containers all: true filter: "name=$container_name"]
    assert_eq $listed_all.len 1
    assert_eq $listed_all[0].id $ctr.id

    ctr.start()
    assert_eq $ctr.state().state :running:

    ctr.restart()
    assert_eq $ctr.state().state :running:

    ctr.remove force: true

    let gone = try
      runtime.container $container_name
      false
    catch runtime.NoContainerError: _
      true
    assert $gone
  finally
    cleanup()
