import exec fs
  std:
    - TypeError
  test:
    - assert
    - assert_eq
    - assert_ne
    - test

def app_name prefix dir
  "$prefix-$(dir.name)"

#[test]
def run_uses_app_scoped_cache()
  fs.with_temp_dir do |dir|
    let app = app_name exec-regression $dir
    let script = (dir / "script.dol")
    script.write "41\n"
    let cache_root = (fs.cache_dir() / app / "bytecode")
    cache_root.remove all: true ignore: true

    try
      assert_eq (exec.run script app: app) 41
      assert $cache_root.exists()
      assert_eq ([...cache_root.entries()].len) 1
      assert_eq (cache_root.entries().next().path.ext) dolc
    finally
      cache_root.remove all: true ignore: true

#[test]
def module_defaults_app_from_program_module_name()
  fs.with_temp_dir do |dir|
    let mod_path = (dir / "demo_mod.dol")
    mod_path.write "pub let answer = 42\n"
    let m = exec.module $mod_path
    assert_eq $m.answer 42

#[test]
def run_rebuilds_invalid_cached_bytecode()
  fs.with_temp_dir do |dir|
    let app = app_name exec-corrupt $dir
    let script = (dir / "script.dol")
    script.write "99\n"
    let cache_root = (fs.cache_dir() / app / "bytecode")
    cache_root.remove all: true ignore: true

    try
      assert_eq (exec.run script app: app) 99
      let file = cache_root.entries().next().path
      file.write b"bad bytecode"
      assert_eq (exec.run script app: app) 99
      assert_ne (file.read "b") b"bad bytecode"
    finally
      cache_root.remove all: true ignore: true

#[test]
def run_injects_globals()
  fs.with_temp_dir do |dir|
    let script = (dir / "script.dol")
    script.write "answer\n"
    assert_eq (exec.run script inject: {answer: 41}) 41

#[test]
def module_injects_globals_during_init()
  fs.with_temp_dir do |dir|
    let mod_path = (dir / "demo_mod.dol")
    mod_path.write "pub let answer = answer\n"
    let m = exec.module $mod_path inject: {answer: 42}
    assert_eq $m.answer 42

#[test]
def run_merges_dict_prelude_with_inject()
  fs.with_temp_dir do |dir|
    let script = (dir / "script.dol")
    script.write r|
      assert_eq $answer 41
      answer
    assert_eq (
      exec.run script
        prelude: {test: [:assert_eq:]}
        inject: {answer: 41}
    ) 41

#[test]
def run_reuses_cache_when_inject_values_change()
  fs.with_temp_dir do |dir|
    let app = app_name exec-inject-cache $dir
    let script = (dir / "script.dol")
    script.write "answer\n"
    let cache_root = (fs.cache_dir() / app / "bytecode")
    cache_root.remove all: true ignore: true

    try
      assert_eq (exec.run script app: app inject: {answer: 1}) 1
      assert_eq (exec.run script app: app inject: {answer: 2}) 2
      assert_eq ([...cache_root.entries()].len) 1
    finally
      cache_root.remove all: true ignore: true

#[test]
def run_rejects_non_dict_inject()
  fs.with_temp_dir do |dir|
    let script = (dir / "script.dol")
    script.write "0\n"
    let ok = try
      exec.run $script inject: 1
      false
    catch TypeError: err
      assert_eq (str err) "type error: inject: expected `dict`"
      true
    assert $ok

#[test]
def run_rejects_non_symbol_inject_key()
  fs.with_temp_dir do |dir|
    let script = (dir / "script.dol")
    script.write "0\n"
    let ok = try
      exec.run $script inject: {"answer": 1}
      false
    catch TypeError: err
      assert_eq (str err) "type error: inject key: expected `sym`"
      true
    assert $ok
